<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SATOI 法人ダッシュボード - Corporate Portal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --night-deep: #0B1736;
  --night-medium: #1A2548;
  --night-glow: #2A3558;
  --starlight: #D4A95E;
  --starlight-soft: #E5C68A;
  --morning-white: #F8F6F0;
  --morning-cream: #F4F2EB;
  --morning-warm: #EDE5D3;
  --healing-blue: #7FA8C9;
  --healing-blue-deep: #4F7AA0;
  --teal: #0D7377;
  --teal-soft: #5BA8AA;
  --warm-orange: #D4622A;
  --warm-coral: #E08461;
  --rose: #C76B7F;
  --ink-deep: #1A2238;
  --ink-medium: #3D4860;
  --ink-light: #6B7388;
  --ink-mute: #9099A8;
  --border: #E2DFD4;
  --success: #2E8B57;
  --danger: #C5443E;
  --warning: #C28F2A;
  --font: "Noto Sans JP", "Hiragino Kaku Gothic ProN", sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { width: 100%; min-height: 100vh; overflow-x: hidden; background: var(--morning-cream); }

body {
  font-family: var(--font);
  color: var(--ink-deep);
  font-size: 15px;
  line-height: 1.65;
  display: flex;
  min-height: 100vh;
}

button, input { font-family: var(--font); }

/* === サイドバー === */
.sidebar {
  width: 240px;
  background: var(--night-deep);
  color: var(--morning-white);
  padding: 28px 0;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
}

.side-logo {
  padding: 0 24px 24px;
  border-bottom: 1px solid rgba(248,246,240,0.08);
  margin-bottom: 18px;
}

.side-logo .logo {
  font-size: 20px;
  font-weight: 500;
  letter-spacing: 0.18em;
  display: inline-flex;
  align-items: center;
}
.side-logo .logo .dot {
  display: inline-block;
  width: 7px; height: 7px;
  background: var(--starlight);
  border-radius: 50%;
  margin-right: 9px;
  box-shadow: 0 0 8px var(--starlight);
}

.side-corp {
  font-size: 11px;
  letter-spacing: 0.28em;
  color: var(--starlight);
  margin-top: 6px;
}

.side-account {
  padding: 0 24px 22px;
  border-bottom: 1px solid rgba(248,246,240,0.08);
  margin-bottom: 14px;
}

.side-corp-name {
  font-size: 13px;
  color: rgba(248,246,240,0.85);
  margin-bottom: 4px;
  letter-spacing: 0.03em;
}

.side-staff {
  font-size: 11px;
  color: rgba(248,246,240,0.45);
}

.side-nav {
  list-style: none;
  padding: 0 12px;
}

.side-nav li { margin-bottom: 4px; }

.side-nav button {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  padding: 10px 14px;
  background: transparent;
  color: rgba(248,246,240,0.78);
  border: none;
  border-radius: 8px;
  font-size: 13px;
  letter-spacing: 0.05em;
  cursor: pointer;
  transition: all 0.25s;
  text-align: left;
}

.side-nav button:hover { background: rgba(248,246,240,0.05); color: var(--morning-white); }
.side-nav button.active { background: rgba(212,169,94,0.18); color: var(--starlight-soft); }
.side-nav button.active::before { content: ''; width: 3px; height: 16px; background: var(--starlight); border-radius: 2px; margin-right: -9px; }

.side-nav-icon { width: 16px; height: 16px; opacity: 0.9; }
.side-nav-icon svg { width: 100%; height: 100%; stroke: currentColor; fill: none; stroke-width: 1.6; }

.side-bottom {
  position: absolute;
  bottom: 24px;
  left: 0; right: 0;
  padding: 0 24px;
}

.side-gov {
  font-size: 10px;
  color: rgba(212,169,94,0.6);
  padding: 10px 12px;
  background: rgba(212,169,94,0.06);
  border-radius: 8px;
  border: 1px solid rgba(212,169,94,0.18);
  line-height: 1.55;
}

/* === メインエリア === */
.main {
  flex: 1;
  min-width: 0;
  padding: 28px 36px 40px;
  overflow-x: hidden;
}

.main-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
  flex-wrap: wrap;
  gap: 12px;
}

.crumbs { font-size: 12px; color: var(--ink-light); letter-spacing: 0.06em; }
.crumbs span:not(:last-child)::after { content: ' / '; margin: 0 4px; color: var(--ink-mute); }
.crumbs span:last-child { color: var(--ink-deep); font-weight: 500; }

.head-actions { display: flex; gap: 10px; align-items: center; }

.search-box {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: var(--morning-white);
  border: 1px solid var(--border);
  border-radius: 22px;
  width: 280px;
}
.search-box input {
  border: none;
  outline: none;
  flex: 1;
  font-size: 13px;
  color: var(--ink-deep);
  background: transparent;
}
.search-box input::placeholder { color: var(--ink-mute); }

.btn-action {
  padding: 8px 18px;
  background: var(--night-deep);
  color: var(--morning-white);
  border: none;
  border-radius: 20px;
  font-size: 12px;
  letter-spacing: 0.06em;
  cursor: pointer;
}
.btn-action.ghost { background: var(--morning-white); color: var(--ink-medium); border: 1px solid var(--border); }
.btn-action:hover { opacity: 0.88; }

/* === ページタイトル === */
.page-title {
  font-size: 26px;
  font-weight: 500;
  letter-spacing: 0.03em;
  margin-bottom: 6px;
}
.page-sub { font-size: 13px; color: var(--ink-light); margin-bottom: 28px; }

/* === タブ === */
.tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--border);
  margin-bottom: 28px;
}
.tab {
  padding: 14px 24px;
  background: none;
  border: none;
  font-size: 14px;
  color: var(--ink-light);
  cursor: pointer;
  position: relative;
  transition: color 0.25s;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
}
.tab:hover { color: var(--ink-medium); }
.tab.active { color: var(--warm-orange); border-bottom-color: var(--warm-orange); font-weight: 500; }

/* === タブパネル === */
.tab-panel { display: none; }
.tab-panel.active { display: block; animation: fadeIn 0.4s; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

/* === KPI バナー === */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  margin-bottom: 28px;
}

.kpi-card {
  background: var(--morning-white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px 22px;
}
.kpi-label { font-size: 11px; color: var(--ink-light); letter-spacing: 0.14em; margin-bottom: 10px; text-transform: uppercase; }
.kpi-num { font-size: 30px; font-weight: 700; color: var(--ink-deep); letter-spacing: 0.02em; line-height: 1.15; margin-bottom: 4px; }
.kpi-trend { font-size: 11px; color: var(--success); display: inline-flex; align-items: center; gap: 4px; font-weight: 500; }
.kpi-trend.down { color: var(--danger); }
.kpi-sub { font-size: 11px; color: var(--ink-mute); margin-top: 6px; }

/* === 顧客テーブル === */
.table-wrap {
  background: var(--morning-white);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}

.table-head {
  padding: 18px 22px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
  gap: 10px;
}
.table-title { font-size: 15px; font-weight: 500; }
.table-filters { display: flex; gap: 8px; flex-wrap: wrap; }
.filter-chip {
  font-size: 11px;
  padding: 6px 14px;
  background: var(--morning-cream);
  border: 1px solid var(--border);
  border-radius: 14px;
  cursor: pointer;
  letter-spacing: 0.04em;
  transition: all 0.2s;
}
.filter-chip:hover { background: var(--morning-warm); }
.filter-chip.active { background: var(--night-deep); color: var(--morning-white); border-color: var(--night-deep); }

table { width: 100%; border-collapse: collapse; font-size: 13px; }
thead th {
  text-align: left;
  padding: 12px 16px;
  font-size: 11px;
  color: var(--ink-light);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 500;
  background: var(--morning-cream);
  border-bottom: 1px solid var(--border);
}

tbody tr { cursor: pointer; transition: background 0.2s; border-bottom: 1px solid var(--border); }
tbody tr:hover { background: var(--morning-cream); }
tbody tr:last-child { border-bottom: none; }

tbody td { padding: 14px 16px; vertical-align: middle; }
.cell-id { font-family: 'SF Mono', Monaco, monospace; font-size: 12px; color: var(--ink-medium); }
.cell-name { font-weight: 500; color: var(--ink-deep); letter-spacing: 0.02em; }
.cell-sub { font-size: 11px; color: var(--ink-light); margin-top: 2px; }

.pill {
  display: inline-block;
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 10px;
  letter-spacing: 0.04em;
  font-weight: 500;
}
.pill.cancer-breast { background: rgba(199,107,127,0.14); color: #8a3551; }
.pill.cancer-colon { background: rgba(13,115,119,0.14); color: #095e62; }
.pill.cancer-lung { background: rgba(127,168,201,0.18); color: #305878; }
.pill.cancer-stomach { background: rgba(212,98,42,0.14); color: #95421c; }
.pill.cancer-prostate { background: rgba(11,23,54,0.1); color: #1A2238; }
.pill.cancer-pancreas { background: rgba(212,169,94,0.18); color: #7a5e22; }

.pill.stage-i { background: rgba(46,139,87,0.14); color: #1d6841; }
.pill.stage-ii { background: rgba(212,169,94,0.18); color: #7a5e22; }
.pill.stage-iii { background: rgba(212,98,42,0.14); color: #95421c; }
.pill.stage-iv { background: rgba(197,68,62,0.14); color: #8a2c27; }

.pill.status-active { background: rgba(46,139,87,0.14); color: #1d6841; }
.pill.status-paid { background: rgba(13,115,119,0.14); color: #095e62; }
.pill.status-pending { background: rgba(194,143,42,0.16); color: #76561a; }

.last-active { font-size: 11px; color: var(--ink-light); }
.dot-online { display: inline-block; width: 6px; height: 6px; background: var(--success); border-radius: 50%; margin-right: 6px; vertical-align: middle; }

/* === モーダル === */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(11,23,54,0.5);
  backdrop-filter: blur(10px);
  display: none;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}
.modal-overlay.open { display: flex; animation: fadeIn 0.3s; }

.modal {
  width: 100%;
  max-width: 760px;
  max-height: 90vh;
  overflow-y: auto;
  background: var(--morning-white);
  border-radius: 16px;
  box-shadow: 0 40px 90px rgba(0,0,0,0.35);
}

.modal-head {
  padding: 28px 32px 18px;
  border-bottom: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
}

.modal-title { font-size: 22px; font-weight: 500; letter-spacing: 0.03em; margin-bottom: 6px; }
.modal-sub { font-size: 12px; color: var(--ink-light); letter-spacing: 0.06em; }
.modal-close {
  width: 36px; height: 36px;
  background: var(--morning-cream);
  border: none;
  border-radius: 50%;
  font-size: 16px;
  cursor: pointer;
  color: var(--ink-medium);
  flex-shrink: 0;
}
.modal-close:hover { background: var(--morning-warm); }

.modal-body { padding: 22px 32px; }

.profile-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
  margin-bottom: 22px;
}
.profile-item {
  padding: 14px 16px;
  background: var(--morning-cream);
  border-radius: 8px;
}
.profile-label { font-size: 10px; color: var(--ink-light); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 4px; }
.profile-value { font-size: 14px; color: var(--ink-deep); font-weight: 500; letter-spacing: 0.02em; }

.section-block {
  margin-bottom: 22px;
}
.section-block-head {
  font-size: 11px;
  letter-spacing: 0.2em;
  color: var(--warm-orange);
  text-transform: uppercase;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-block-head::after { content: ''; flex: 1; height: 1px; background: var(--border); }

.benefit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}
.benefit-card {
  padding: 12px 14px;
  background: var(--morning-cream);
  border-radius: 8px;
}
.benefit-label { font-size: 10px; color: var(--ink-light); margin-bottom: 4px; letter-spacing: 0.1em; }
.benefit-val { font-size: 16px; font-weight: 700; color: var(--ink-deep); }
.benefit-val.warm { color: var(--warm-orange); }
.benefit-val.teal { color: var(--teal); }

.activity-list { list-style: none; padding: 0; margin: 0; }
.activity-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px dashed var(--border);
  font-size: 13px;
}
.activity-item:last-child { border-bottom: none; }
.activity-date { color: var(--ink-light); font-size: 11px; min-width: 80px; letter-spacing: 0.04em; }
.activity-text { flex: 1; color: var(--ink-deep); }
.activity-tag { font-size: 10px; padding: 2px 8px; background: rgba(127,168,201,0.15); color: var(--teal); border-radius: 8px; }

.modal-cta-row {
  padding: 22px 32px 28px;
  border-top: 1px solid var(--border);
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.cta-immerse {
  flex: 1;
  min-width: 280px;
  padding: 16px 24px;
  background: linear-gradient(135deg, var(--warm-orange), var(--warm-coral));
  color: var(--morning-white);
  border: none;
  border-radius: 28px;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.06em;
  cursor: pointer;
  box-shadow: 0 8px 20px rgba(212,98,42,0.28);
  transition: all 0.3s;
}
.cta-immerse:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(212,98,42,0.4); }

.cta-secondary {
  padding: 16px 24px;
  background: var(--morning-cream);
  color: var(--ink-medium);
  border: 1px solid var(--border);
  border-radius: 28px;
  font-size: 14px;
  cursor: pointer;
}
.cta-secondary:hover { background: var(--morning-warm); }

.modal-privacy {
  padding: 16px 32px 24px;
  background: var(--morning-cream);
  font-size: 11px;
  color: var(--ink-light);
  text-align: center;
  line-height: 1.6;
  letter-spacing: 0.04em;
}

/* === 保険プランタブ === */
.simulator {
  background: var(--morning-white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 30px 32px;
  margin-bottom: 24px;
}

.sim-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px;
  margin-bottom: 22px;
}

.sim-field { display: flex; flex-direction: column; gap: 8px; }
.sim-label { font-size: 12px; color: var(--ink-light); letter-spacing: 0.06em; }
.sim-input {
  padding: 12px 16px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 14px;
  color: var(--ink-deep);
  background: var(--morning-cream);
}
.sim-input:focus { outline: none; border-color: var(--warm-orange); }

.sim-result {
  background: linear-gradient(135deg, var(--night-deep), var(--night-medium));
  color: var(--morning-white);
  border-radius: 12px;
  padding: 28px;
}
.sim-result-label { font-size: 11px; color: var(--starlight); letter-spacing: 0.3em; margin-bottom: 12px; }
.sim-result-num { font-size: 38px; font-weight: 700; color: var(--starlight); margin-bottom: 18px; letter-spacing: 0.02em; }
.sim-result-breakdown { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; font-size: 12px; }
.sim-result-item { padding: 10px 12px; background: rgba(248,246,240,0.06); border-radius: 8px; }
.sim-result-item-label { color: rgba(248,246,240,0.55); margin-bottom: 4px; font-size: 10px; letter-spacing: 0.08em; }
.sim-result-item-val { font-size: 14px; color: var(--morning-white); font-weight: 500; }

/* === 「今やるべきこと」 === */
.todo-section {
  background: var(--morning-white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px 32px;
}
.todo-list { list-style: none; padding: 0; margin-top: 18px; }
.todo-item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 16px 0;
  border-bottom: 1px solid var(--border);
}
.todo-item:last-child { border-bottom: none; }
.todo-check {
  width: 22px; height: 22px;
  flex-shrink: 0;
  border: 1.5px solid var(--ink-mute);
  border-radius: 6px;
  margin-top: 2px;
  cursor: pointer;
  transition: all 0.2s;
}
.todo-check.done { background: var(--success); border-color: var(--success); }
.todo-body { flex: 1; }
.todo-title { font-size: 14px; font-weight: 500; color: var(--ink-deep); margin-bottom: 4px; }
.todo-sub { font-size: 12px; color: var(--ink-light); }
.todo-meta { font-size: 11px; color: var(--ink-mute); margin-top: 6px; }
.todo-action {
  padding: 6px 14px;
  background: var(--warm-orange);
  color: var(--morning-white);
  border: none;
  border-radius: 14px;
  font-size: 11px;
  cursor: pointer;
  align-self: center;
  flex-shrink: 0;
}

/* === グラフ風(SVG) === */
.chart-card {
  background: var(--morning-white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px 28px;
  margin-bottom: 24px;
}
.chart-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
.chart-title { font-size: 15px; font-weight: 500; }
.chart-legend { display: flex; gap: 14px; font-size: 11px; color: var(--ink-light); }
.legend-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 5px; vertical-align: middle; }

/* === ターゲティング配信 === */
.tgt-group { margin-bottom: 18px; }
.tgt-label {
  display: block;
  font-size: 11px;
  color: var(--ink-light);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 10px;
  font-weight: 500;
}
.tgt-checks { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 12px; }
.tgt-checks label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--ink-deep);
  cursor: pointer;
  padding: 4px 0;
}
.tgt-checks input[type="checkbox"] {
  accent-color: var(--warm-orange);
  width: 14px; height: 14px;
}

.msg-type {
  padding: 8px 14px;
  background: var(--morning-cream);
  border: 1px solid var(--border);
  border-radius: 20px;
  font-size: 12px;
  cursor: pointer;
  font-family: var(--font);
  letter-spacing: 0.04em;
  transition: all 0.2s;
}
.msg-type:hover { background: var(--morning-warm); }
.msg-type.active {
  background: var(--night-deep);
  color: var(--morning-white);
  border-color: var(--night-deep);
}
.msg-type.sns {
  background: rgba(127,168,201,0.1);
  border-color: rgba(127,168,201,0.4);
  color: var(--healing-blue-deep);
}
.msg-type.sns:hover { background: rgba(127,168,201,0.22); }
.msg-type.sns.active {
  background: var(--healing-blue-deep);
  color: var(--morning-white);
  border-color: var(--healing-blue-deep);
}

/* === がん種バー === */
.cancer-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 0;
}
.cancer-bar-label { width: 90px; font-size: 13px; color: var(--ink-deep); }
.cancer-bar-track { flex: 1; height: 22px; background: var(--morning-cream); border-radius: 4px; position: relative; }
.cancer-bar-fill { height: 100%; border-radius: 4px; }
.cancer-bar-num { width: 80px; text-align: right; font-size: 12px; color: var(--ink-medium); font-weight: 500; }

/* === 都道府県ヒートマップセル === */
.pref-cell {
  aspect-ratio: 1;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 9px;
  color: rgba(11,23,54,0.7);
  text-align: center;
  line-height: 1;
  cursor: pointer;
  font-weight: 500;
  transition: transform 0.2s;
}
