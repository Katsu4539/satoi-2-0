function updateSim() {
  const cancer = document.getElementById('simCancer').value;
  const stage = document.getElementById('simStage').value;
  const plan = document.getElementById('simPlan').value;
  const income = document.getElementById('simIncome').value;

  const baseDiagnosis = { standard: 1000000, premium: 1500000, all: 2200000 }[plan];
  const stageMultiplier = { I: 1, II: 1, III: 1.2, IV: 1.5 }[stage];
  const cancerMultiplier = { breast: 1, colon: 1, lung: 1.1, stomach: 1, prostate: 0.9, pancreas: 1.3 }[cancer];
  const treatmentPerCycle = { standard: 150000, premium: 250000, all: 380000 }[plan];
  const taxRate = { low: 0.05, mid: 0.10, high: 0.20, top: 0.33 }[income];

  const diagnosis = Math.round(baseDiagnosis * cancerMultiplier);
  const treatment = treatmentPerCycle;
  const annual = diagnosis + treatment * 4;
  const taxDeduction = Math.round(annual * 0.12 * taxRate * 10);

  const total = diagnosis + (treatment * 4 * stageMultiplier) + taxDeduction;

  const fmt = n => '¥' + n.toLocaleString();

  document.getElementById('simTotal').textContent = fmt(Math.round(total));
  document.getElementById('simDiagnosis').textContent = fmt(diagnosis);
  document.getElementById('simTreatment').textContent = fmt(treatment);
  document.getElementById('simTax').textContent = fmt(taxDeduction);
}

