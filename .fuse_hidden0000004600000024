// === ターゲティング配信ロジック ===
(function targetingLogic() {
  function calcTarget() {
    const ck = (key) => Array.from(document.querySelectorAll(`.tgt-checks[data-key="${key}"] input:checked`)).length;
    const cancerN = ck('cancer');
    const stageN = ck('stage');
    const typeN = ck('type');
    const ageN = ck('age');
    const activityN = ck('activity');
    const insuranceN = ck('insurance');
    const area = document.getElementById('tgtArea').value;
    const areaFactor = { all:1.0, kanto:0.42, kansai:0.22, chubu:0.16, kyushu:0.12, other:0.08 }[area] || 1.0;

    // 簡易な掛け算ベースの推定
    let base = 21184; // 同意済み総数
    base *= cancerN === 0 ? 0 : Math.min(cancerN / 6 * 1.05, 1);
    base *= stageN === 0 ? 0 : Math.min(stageN / 4 * 1.1, 1);
    base *= typeN === 0 ? 0 : Math.min(typeN / 2 * 1.05, 1);
    base *= ageN === 0 ? 0 : Math.min(ageN / 6 * 1.1, 1);
    base *= activityN === 0 ? 0 : Math.min(activityN / 3 * 1.0, 1);
    base *= insuranceN === 0 ? 0 : Math.min(insuranceN / 3 * 1.0, 1);
    base *= areaFactor;

    const count = Math.round(base);
    const cost = count * 48;

    const countEl = document.getElementById('tgtCount');
    const costEl = document.getElementById('tgtCost');
    const sendBtnNum = document.getElementById('sendBtnNum');
    if (countEl) countEl.textContent = count.toLocaleString();
    if (costEl) costEl.textContent = '¥' + cost.toLocaleString();
    if (sendBtnNum) sendBtnNum.textContent = count.toLocaleString();

    // 内訳:自社/他社/未加入
    const insChecks = document.querySelectorAll('.tgt-checks[data-key="insurance"] input');
    let ownShare = 0, otherShare = 0, noneShare = 0;
    insChecks.forEach(i => {
      if (i.checked) {
        if (i.value === 'own') ownShare = 0.06;
        if (i.value === 'other') otherShare = 0.47;
        if (i.value === 'none') noneShare = 0.47;
      }
    });
    const total = ownShare + otherShare + noneShare || 1;
    const ownEl = document.getElementById('tgtOwn');
    const otherEl = document.getElementById('tgtOther');
    const noneEl = document.getElementById('tgtNone');
    if (ownEl) ownEl.textContent = Math.round(count * ownShare / total).toLocaleString();
    if (otherEl) otherEl.textContent = Math.round(count * otherShare / total).toLocaleString();
    if (noneEl) noneEl.textContent = Math.round(count * noneShare / total).toLocaleString();

    // AIサジェスチョン更新
    updateAiSuggest();
  }

  function updateAiSuggest() {
    const cancers = Array.from(document.querySelectorAll('.tgt-checks[data-key="cancer"] input:checked')).map(i => i.value);
    const stages = Array.from(document.querySelectorAll('.tgt-checks[data-key="stage"] input:checked')).map(i => i.value);
    const ages = Array.from(document.querySelectorAll('.tgt-checks[data-key="age"] input:checked')).map(i => i.value);

    const cancerLabel = { breast:'乳がん', colon:'大腸がん', lung:'肺がん', stomach:'胃がん', prostate:'前立腺がん', pancreas:'膵がん' };
    const cancerStr = cancers.map(c => cancerLabel[c]).join('・') || '(がん種未指定)';
    const stageStr = stages.length ? 'ステージ ' + stages.join('/') : '(ステージ未指定)';
    const ageStr = ages.length ? ages.map(a => a + '代').join('・') : '(年代未指定)';

    const desc = `${ageStr} の <strong>${cancerStr} ${stageStr}</strong> アクティブ患者 — 治療継続+副作用支援+家族サポートを重視するペルソナ`;
    const descEl = document.getElementById('aiSuggestDesc');
    if (descEl) descEl.innerHTML = desc;
  }

  document.querySelectorAll('.tgt-checks input').forEach(el => el.addEventListener('change', calcTarget));
  const areaEl = document.getElementById('tgtArea');
  if (areaEl) areaEl.addEventListener('change', calcTarget);

  // メッセージプレビュー連動
  function updatePreview() {
    const subj = document.getElementById('msgSubject').value;
    const body = document.getElementById('msgBody').value
      .replace(/\{\{name\}\}/g, 'M.S.')
      .replace(/\{\{cancer\}\}/g, '乳がん')
      .replace(/\{\{stage\}\}/g, 'II');
    const cta = document.getElementById('msgCta').value;
    const subEl = document.getElementById('prevSubject');
    const bodyEl = document.getElementById('prevBody');
    const ctaEl = document.getElementById('prevCta');
    if (subEl) subEl.textContent = subj;
    if (bodyEl) bodyEl.textContent = body;
    if (ctaEl) ctaEl.innerHTML = cta + '  →';
  }
  ['msgSubject','msgBody','msgCta'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', updatePreview);
  });

  // メッセージタイプ切替
  document.querySelectorAll('.msg-type').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.msg-type').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const type = btn.dataset.type;
      const presets = {
        dm: {
          subject: 'あなたに合う、新しい治療給付のお知らせ',
          body: '{{name}}さん、いつもSATOIをご利用いただきありがとうございます。\n\n{{cancer}} ステージ{{stage}}の方向けに、新しく対応可能となった給付プランがあります。\n\nご状況に合わせた給付シミュレーションを、SATOI上で確認できます。',
          cta: 'シミュレーションを見る'
        },
        survey: {
          subject: '【任意・3分】副作用とお気持ちのご様子を教えてください',
          body: '{{name}}さん、いつもSATOIをご利用いただきありがとうございます。\n\n{{cancer}}の治療を続ける中で、副作用やお気持ちはいかがでしょうか?\n\n3分のアンケートにご協力いただけると、今後のサポート設計に活かさせていただきます。',
          cta: 'アンケートに答える(+200pt)'
        },
        seminar: {
          subject: '【オンラインセミナー】{{cancer}}の最新治療と給付の活かし方',
          body: '{{name}}さんへ\n\n{{cancer}}の最新治療と、保険給付の組み合わせ方を、専門家と現役患者がお話しします。\n\n日時:6月10日(月)19:00〜20:30\nオンライン無料・録画あり',
          cta: 'セミナーに申し込む'
        },
        benefit: {
          subject: '【重要】あなたが使える給付・制度のチェックリスト',
          body: '{{name}}さん、いつもありがとうございます。\n\n{{cancer}} ステージ{{stage}}の方が使える給付・公的制度をAIが整理しました。\n\n未申請の制度が 3件 あります(高額療養費・治療給付・医療費控除)。',
          cta: 'チェックリストを開く'
        },
        youtube: {
          subject: '【動画でわかる】{{cancer}}と保険の使い方・10分で',
          body: '{{name}}さんへ\n\n{{cancer}}の治療と保険の活かし方を、10分の動画にまとめました。\n医師・先輩患者・FPの3人が、それぞれの視点でお話ししています。\n\n再生時間 9:42・SATOI内で視聴可能(外部視聴履歴は残りません)',
          cta: '動画を見る  ▶'
        },
        community: {
          subject: 'コミュニティ投稿:DEMO 生命保険 公式アカウントより',
          body: '{{name}}さん、こんにちは。DEMO生命保険 公式アカウントです。\n\n本日、{{cancer}}向けの新プラン情報を SATOI コミュニティに投稿しました。\nコメント・質問もそのままお寄せください。同じプランを検討中の方の声も読めます。\n\n#がん保険 #{{cancer}} #SATOI公式',
          cta: 'コミュニティ投稿を読む'
        },
        push: {
          subject: '【SATOIアプリ通知】給付申請が間もなく可能になります',
          body: '{{name}}さん、{{cancer}} ステージ{{stage}}の治療給付申請が、次回受診後すぐに行えます。\n\n書類はSATOI内で自動生成済み。ワンタップで提出可能。',
          cta: 'アプリで確認する'
        },
        call: {
          subject: '専属コンシェルジュとの30分通話、ご希望ですか?',
          body: '{{name}}さんへ\n\n保険給付・公的制度・治療費の見通しを、専属コンシェルジュと電話で整理しませんか?\n\n土日夜含む 平日10時〜21時 / 完全無料 / 録音任意 / お話だけでも歓迎',
          cta: '通話日程を選ぶ'
        }
      };
      const preset = presets[type];
      if (preset) {
        document.getElementById('msgSubject').value = preset.subject;
        document.getElementById('msgBody').value = preset.body;
        document.getElementById('msgCta').value = preset.cta;
        updatePreview();
      }
    });
  });

  // AI プランクリックで配信メッセージ自動カスタマイズ
  document.querySelectorAll('[data-plan]').forEach(card => {
    card.addEventListener('click', () => {
      const plan = card.dataset.plan;
      const planLabel = { premium: 'プレミアム がん特約', all: 'オール・サポート', standard: 'スタンダード' }[plan];
      const planDetail = {
        premium: '月¥6,400・診断給付¥150万・治療給付¥25万/クール',
        all: '月¥9,200・診断給付¥220万・家族支援込・セカンドオピニオン全額',
        standard: '月¥3,800・診断給付¥100万・がん経験者プラン'
      }[plan];

      // 見た目のフォーカス更新
      document.querySelectorAll('[data-plan]').forEach(c => {
        c.style.background = 'rgba(248,246,240,0.05)';
        c.style.borderColor = 'rgba(248,246,240,0.15)';
      });
      card.style.background = 'rgba(248,246,240,0.12)';
      card.style.borderColor = 'rgba(212,169,94,0.5)';

      // メッセージプリセット自動更新
      document.getElementById('msgSubject').value = '【あなたに最適】' + planLabel + ' のご案内';
      document.getElementById('msgBody').value = '{{name}}さんへ\n\nSATOI AI が、あなたの状況を分析しました。\n{{cancer}} ステージ{{stage}}の方には、当社の <strong>' + planLabel + '</strong> が最も合うと判定しました。\n\n' + planDetail + '\n\n同じプランをご利用中の方の物語や、給付シミュレーションを SATOI内でご確認いただけます。';
      document.getElementById('msgCta').value = planLabel + 'を見る';
      updatePreview();

      // 配信元アカウント表示も更新
      const prevFrom = document.getElementById('prevFrom');
      if (prevFrom) prevFrom.textContent = 'DEMO 生命保険 公式 ✓';
    });
  });

  // 配信ボタン
  const sendBtn = document.getElementById('sendBtn');
  if (sendBtn) {
    sendBtn.addEventListener('click', () => {
      const n = document.getElementById('tgtCount').textContent;
      const orig = sendBtn.innerHTML;
      sendBtn.innerHTML = '配信中... ●●●';
      sendBtn.style.opacity = '0.7';
      setTimeout(() => {
        sendBtn.innerHTML = '✓ 配信完了:' + n + '名 に送信されました';
        sendBtn.style.background = 'var(--success)';
        setTimeout(() => {
          sendBtn.innerHTML = orig;
          sendBtn.style.opacity = '1';
          sendBtn.style.background = 'var(--night-deep)';
        }, 4000);
      }, 1400);
    });
  }

  calcTarget();
})();
</script>

<script src="satoi_common.js"></script>
</body>
