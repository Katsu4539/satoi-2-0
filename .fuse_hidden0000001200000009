<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SATOI - 今日の振り返り</title>
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #FBF7F0;
  --ink-deep: #1A2A40;
  --ink-mid: #4A5570;
  --ink-light: #8893A8;
  --line: rgba(11,23,54,0.10);
  --accent: #D4A95E;
  --teal: #0D7377;
  --warm: #D4622A;
  --font: 'Noto Sans JP', sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--font); background: var(--bg); color: var(--ink-deep); line-height: 1.7; -webkit-font-smoothing: antialiased; }

.header {
  position: sticky; top: 0; z-index: 50;
  background: rgba(251,247,240,0.92);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--line);
  padding: 16px 28px; display: flex; align-items: center; gap: 18px;
}
.logo { font-weight: 700; letter-spacing: 0.22em; color: var(--ink-deep); font-size: 15px; }
.logo .dot { display:inline-block; width:8px; height:8px; background: var(--accent); border-radius: 50%; margin-right: 8px; vertical-align: middle; }
.back-link { margin-left: auto; padding: 8px 16px; background: white; border: 1px solid var(--line); border-radius: 18px; color: var(--ink-deep); text-decoration: none; font-size: 13px; }
.back-link:hover { border-color: var(--accent); }

.main { max-width: 880px; margin: 0 auto; padding: 40px 28px 80px; }

.review-eyebrow { font-size: 11.5px; color: var(--ink-light); letter-spacing: 0.22em; margin-bottom: 8px; }
.review-title { font-size: 28px; font-weight: 700; margin-bottom: 8px; letter-spacing: 0.04em; }
.review-sub { color: var(--ink-mid); font-size: 14.5px; margin-bottom: 32px; }

.ai-summary {
  background: linear-gradient(135deg, rgba(212,169,94,0.08), rgba(13,115,119,0.06));
  border: 1px solid rgba(212,169,94,0.25);
  border-radius: 18px;
  padding: 26px 28px; margin-bottom: 36px; position: relative;
}
.ai-summary-eyebrow { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; font-size: 12.5px; color: var(--accent); font-weight: 600; letter-spacing: 0.18em; }
.ai-summary-icon { width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, #D4A95E, #D4622A); color: white; display: inline-flex; align-items: center; justify-content: center; font-size: 16px; }
.ai-summary-body { font-size: 15.5px; line-height: 1.9; color: var(--ink-deep); white-space: pre-wrap; }
.ai-summary-loading { color: var(--ink-light); font-size: 13.5px; }
.ai-summary-btn { margin-top: 14px; padding: 10px 20px; background: var(--accent); color: var(--ink-deep); border: none; border-radius: 22px; font-size: 13px; font-weight: 600; cursor: pointer; }

.timeline-section { margin-bottom: 36px; }
.section-title { font-size: 18px; font-weight: 700; margin-bottom: 18px; }

.timeline { position: relative; padding-left: 28px; border-left: 2px solid var(--line); }
.tl-item { position: relative; padding-bottom: 20px; }
.tl-item::before {
  content: ''; position: absolute; left: -36px; top: 5px;
  width: 14px; height: 14px; border-radius: 50%;
  background: white; border: 2px solid var(--accent);
}
.tl-item.click::before { background: var(--accent); }
.tl-time { font-size: 11.5px; color: var(--ink-light); letter-spacing: 0.06em; margin-bottom: 3px; }
.tl-action { font-size: 14px; color: var(--ink-deep); }
.tl-action .tag { display: inline-block; padding: 2px 8px; background: rgba(13,115,119,0.10); color: var(--teal); border-radius: 10px; font-size: 11px; margin-right: 6px; font-weight: 500; }
.tl-action .tag.click { background: rgba(212,169,94,0.18); color: var(--warm); }
.tl-action .text { color: var(--ink-mid); font-size: 13.5px; }

.empty { padding: 40px; text-align: center; color: var(--ink-light); font-size: 14px; }

.actions { display: flex; gap: 14px; margin-top: 36px; flex-wrap: wrap; }
.action-btn { padding: 14px 24px; background: var(--accent); color: var(--ink-deep); border: none; border-radius: 28px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; }
.action-btn.ghost { background: transparent; border: 1px solid var(--line); color: var(--ink-deep); }
.action-btn:hover { transform: translateY(-1px); }
</style>
</head>
<body>

<header class="header">
  <a href="SATOI_Mock_v1_C1_mypage.html" class="logo"><span class="dot"></span>SATOI</a>
  <a href="SATOI_Mock_v1_C1_mypage.html" class="back-link">← マイページに戻る</a>
</header>

<main class="main">
  <div class="review-eyebrow">TODAY'S JOURNEY</div>
  <h1 class="review-title" id="reviewTitle">今日の振り返り</h1>
  <div class="review-sub" id="reviewSub">あなたが今日歩いた道を、AIが見ています。</div>

  <!-- AI要約 -->
  <div class="ai-summary">
    <div class="ai-summary-eyebrow">
      <span class="ai-summary-icon">🤖</span> SATOI AI による振り返り
    </div>
    <div class="ai-summary-body" id="aiSummaryBody">
      <span class="ai-summary-loading">「AIに要約を頼む」を押すと、今日のあなたの動きを、優しく要約してくれます。</span>
    </div>
    <button class="ai-summary-btn" id="aiSummaryBtn" onclick="generateReviewSummary()">🔄 AIに要約を頼む</button>
  </div>

  <!-- 時系列タイムライン -->
  <section class="timeline-section">
    <h2 class="section-title">あなたが歩いた道(時系列)</h2>
    <div class="timeline" id="timeline">
      <div class="empty">読み込み中…</div>
    </div>
  </section>

  <div class="actions">
    <a href="SATOI_Mock_v1_A2_dialog.html?resume=1&from=review" class="action-btn">今日の振り返りから、AIと話す →</a>
    <a href="SATOI_Mock_v1_C1_mypage.html" class="action-btn ghost">マイページに戻る</a>
  </div>
</main>

<script src="satoi_common.js"></script>
<script src="satoi_chat_api.js"></script>
<script>
(function renderTimeline(){
  const log = window.satoiLog ? window.satoiLog.read() : [];
  const tl = document.getElementById('timeline');
  if (!log.length) {
    tl.innerHTML = '<div class="empty">今日はまだ、記録がありません。<br>SATOIの画面をいくつか歩いてみてから、また来てください。</div>';
    return;
  }
  // 同じ画面の連続viewはまとめる
  const compact = [];
  for (const e of log) {
    const last = compact[compact.length - 1];
    if (last && last.type === e.type && last.page === e.page && (e.type === 'view' || last.text === e.text)) {
      last.lastTs = e.ts;
      continue;
    }
    compact.push(Object.assign({}, e, { lastTs: e.ts }));
  }
  tl.innerHTML = compact.map(e => {
    const t = new Date(e.ts);
    const time = String(t.getHours()).padStart(2,'0') + ':' + String(t.getMinutes()).padStart(2,'0');
    if (e.type === 'view') {
      return `<div class="tl-item view">
        <div class="tl-time">${time}</div>
        <div class="tl-action"><span class="tag">📄 閲覧</span><span class="text">${escapeHtml(e.title || e.page)}</span></div>
      </div>`;
    } else {
      const tagText = e.href ? '🔗 リンク' : '👆 操作';
      return `<div class="tl-item click">
        <div class="tl-time">${time}</div>
        <div class="tl-action"><span class="tag click">${tagText}</span><span class="text">${escapeHtml(e.text)}</span></div>
      </div>`;
    }
  }).join('');

  // 振り返りサブ
  const first = log[0];
  const last = log[log.length - 1];
  const ft = new Date(first.ts);
  const lt = new Date(last.ts);
  const subEl = document.getElementById('reviewSub');
  subEl.textContent = `${ft.getHours()}:${String(ft.getMinutes()).padStart(2,'0')} から ${lt.getHours()}:${String(lt.getMinutes()).padStart(2,'0')} まで、${log.length} 件の歩みが記録されています。`;
})();

async function generateReviewSummary(){
  const btn = document.getElementById('aiSummaryBtn');
  const body = document.getElementById('aiSummaryBody');
  if (!window.satoiChatApi) {
    body.innerHTML = '<span class="ai-summary-loading">AI連携モジュールが読み込まれていません。</span>';
    return;
  }
  const log = window.satoiLog.read();
  if (!log.length) {
    body.textContent = '今日はまだ記録がありません。';
    return;
  }
  btn.disabled = true;
  btn.textContent = 'AI生成中…';
  body.innerHTML = '<span class="ai-summary-loading">あなたの今日を、AIが、ゆっくり読み返しています…</span>';
  try {
    const compact = log.slice(-50).map(e => ({
      time: new Date(e.ts).toISOString().slice(11,16),
      type: e.type,
      page: e.page,
      title: e.title || e.text || ''
    }));
    const system = `あなたは SATOI のAIです。下記は、がん患者ご本人が今日 SATOI 上で歩いた行動ログです。
これを読んで、ご本人へ優しく短く(150〜250文字)、今日の歩みを物語のように振り返ってください。
- 3〜5文。最後に「明日、何が出来そうか」を一言添える。
- 65〜70歳のご本人にも読みやすい、ゆとりのある言葉づかいで。
- 専門用語は避ける。
- 急がせない・励まし過ぎない。寄り添うトーン。`;
    const user = '今日のログ:\n' + JSON.stringify(compact, null, 2);
    const result = await window.satoiChatApi.askClaude(user, { system: system, max_tokens: 700 });
    body.textContent = result.reply;
    btn.textContent = '🔄 AIに再要約してもらう';
    btn.disabled = false;
  } catch(err) {
    body.innerHTML = '<span class="ai-summary-loading">要約の生成に失敗しました:' + escapeHtml(err.message || String(err)) + '</span>';
    btn.textContent = '🔄 もう一度試す';
    btn.disabled = false;
  }
}

function escapeHtml(s){
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]);
}
</script>

</body>
</html>
