<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SATOI - ファミリービュー・大切な方の、いま</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --night-deep: #0B1736;
  --night-medium: #1A2548;
  --dawn-pink: #D8A98A;
  --morning-cream: #F6EFE3;
  --morning-white: #FBF7F0;
  --starlight: #D4A95E;
  --starlight-strong: #F0C97A;
  --teal: #0D7377;
  --teal-soft: #14A6AB;
  --warm-orange: #D4622A;
  --money-green: #2D8659;
  --urgent-red: #B85450;
  --rose: #D88A95;
  --navy: #0A1628;
  --bg-cream: #FBF8F2;
  --bg-soft: #F4EFE6;
  --bg-paper: #FFFCF6;
  --line: rgba(10,22,40,0.10);
  --line-soft: rgba(10,22,40,0.06);
  --text-primary: #1A2A40;
  --text-secondary: rgba(26,42,64,0.72);
  --text-muted: rgba(26,42,64,0.50);
  --text-on-dark: rgba(248,246,240,0.96);
  --text-on-dark-soft: rgba(248,246,240,0.74);
  --font: "Noto Sans JP", "Meiryo UI", "Meiryo", "Hiragino Kaku Gothic ProN", sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { width:100%; min-height:100vh; overflow-x:hidden; }
body { font-family: var(--font); color: var(--text-primary); background: var(--morning-white); line-height: 1.85; font-size: 16px; }

.header {
  position: fixed; top:0; left:0; right:0; z-index:200;
  padding: 14px 30px;
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(to bottom, rgba(11,23,54,0.92), rgba(11,23,54,0));
  backdrop-filter: blur(12px);
}
.logo { font-size: 22px; font-weight: 500; letter-spacing: 0.22em; color: var(--text-on-dark); display: inline-flex; align-items: center; text-decoration: none; }
.logo .dot { display: inline-block; width: 8px; height: 8px; background: var(--starlight); border-radius: 50%; margin-right: 10px; box-shadow: 0 0 12px var(--starlight); }
.header-crumb { font-size: 12px; color: var(--text-on-dark-soft); letter-spacing: 0.1em; }
.h-right { display: flex; align-items: center; gap: 10px; }
.h-link { color: var(--text-on-dark-soft); text-decoration: none; font-size: 13px; padding: 8px 14px; border-radius: 18px; transition: background 0.2s; }
.h-link:hover { background: rgba(248,246,240,0.08); }

.hero {
  position: relative;
  padding: 110px 36px 50px;
  background: linear-gradient(180deg, var(--night-deep) 0%, var(--night-medium) 40%, var(--rose) 85%, var(--morning-cream) 100%);
  color: var(--text-on-dark);
  overflow: hidden; text-align: center;
}
.hero-stars { position: absolute; inset: 0; pointer-events: none; }
.h-star { position: absolute; background: var(--starlight); border-radius: 50%; opacity: 0; animation: twinkle 4.5s infinite ease-in-out; }
@keyframes twinkle { 0%,100%{opacity:.15;transform:scale(.7);} 50%{opacity:.75;transform:scale(1.1);} }

.hero-eyebrow { font-size: 12px; letter-spacing: 0.32em; color: var(--text-on-dark-soft); margin-bottom: 16px; }
.hero-greet { font-size: 17px; color: var(--text-on-dark-soft); margin-bottom: 12px; font-weight: 300; }
.hero-title { font-size: 38px; font-weight: 300; letter-spacing: 0.04em; line-height: 1.35; color: var(--text-on-dark); margin-bottom: 18px; }
.hero-title strong { color: var(--starlight-strong); font-weight: 500; }
.hero-sub { font-size: 14px; color: var(--text-on-dark-soft); line-height: 2; max-width: 620px; margin: 0 auto 24px; }
.hero-stat { display: inline-flex; align-items: center; gap: 10px; padding: 10px 22px; background: rgba(248,246,240,0.10); border: 1px solid rgba(248,246,240,0.22); border-radius: 22px; font-size: 13px; }
.hero-stat strong { color: var(--starlight-strong); font-weight: 600; }

.section { max-width: 1100px; margin: 0 auto; padding: 50px 30px; }
.section.bg { background: var(--bg-cream); max-width: none; padding-left: 0; padding-right: 0; }
.section.bg > .section-inner { max-width: 1100px; margin: 0 auto; padding: 0 30px; }
.section-eyebrow { font-size: 12px; letter-spacing: 0.32em; color: var(--teal); text-transform: uppercase; margin-bottom: 10px; }
.section-title { font-size: 24px; font-weight: 400; letter-spacing: 0.04em; line-height: 1.45; margin-bottom: 12px; color: var(--text-primary); }
.section-sub { font-size: 13.5px; color: var(--text-secondary); line-height: 2; margin-bottom: 28px; max-width: 720px; }

/* ① 患者の状態カード */
.patient-card {
  background: var(--bg-paper);
  border: 1px solid var(--line);
  border-radius: 22px;
  padding: 32px;
}
.patient-head {
  display: grid;
  grid-template-columns: 72px 1fr auto;
  gap: 18px;
  align-items: center;
  margin-bottom: 24px;
  padding-bottom: 22px;
  border-bottom: 1px solid var(--line);
}
.patient-avatar {
  width: 64px; height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--starlight), var(--warm-orange));
  color: var(--morning-white);
  display: flex; align-items: center; justify-content: center;
  font-size: 26px;
}
.patient-name { font-size: 18px; font-weight: 500; margin-bottom: 4px; }
.patient-status {
  display: inline-block;
  padding: 4px 12px;
  background: rgba(13,115,119,0.10);
  color: var(--teal);
  border-radius: 12px;
  font-size: 12px;
}
.patient-update { font-size: 11px; color: var(--text-muted); text-align: right; }

.patient-cells {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  gap: 14px;
}
.p-cell {
  background: var(--morning-white);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 16px 18px;
}
.p-cell-label { font-size: 11px; color: var(--text-muted); letter-spacing: 0.06em; margin-bottom: 6px; }
.p-cell-value { font-size: 15px; font-weight: 500; color: var(--text-primary); line-height: 1.5; }
.p-cell-mini { font-size: 12px; color: var(--text-secondary); margin-top: 4px; }

/* ② 患者からのメッセージ */
.msg-list { display: grid; gap: 12px; }
.msg-card {
  background: var(--bg-paper);
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 20px 24px;
  display: grid;
  grid-template-columns: 90px 1fr;
  gap: 18px;
  align-items: start;
}
.msg-card.tonight { border-color: var(--rose); background: linear-gradient(135deg, rgba(216,138,149,0.04), var(--bg-paper)); }
.msg-time { font-size: 11px; color: var(--text-muted); letter-spacing: 0.04em; }
.msg-body { font-size: 14px; line-height: 1.9; color: var(--text-primary); font-style: italic; }
.msg-body strong { color: var(--rose); font-weight: 500; font-style: normal; }
.msg-actions { display: flex; gap: 8px; margin-top: 14px; flex-wrap: wrap; }
.msg-btn {
  background: transparent; color: var(--teal); border: 1px solid var(--teal);
  padding: 6px 14px; border-radius: 14px; font-family: var(--font); font-size: 11.5px; cursor: pointer;
}
.msg-btn:hover { background: var(--teal); color: var(--morning-white); }

/* ③ AIレコメンド */
.ai-rec {
  background: linear-gradient(135deg, rgba(13,115,119,0.06), var(--bg-paper));
  border: 1px solid rgba(13,115,119,0.20);
  border-radius: 22px;
  padding: 28px 32px;
}
.ai-rec-head { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
.ai-orb-mini {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--starlight-strong), var(--starlight) 60%, rgba(212,169,94,0.2));
  box-shadow: 0 0 12px rgba(212,169,94,0.4);
  animation: orb-pulse 3s ease-in-out infinite;
}
@keyframes orb-pulse { 0%,100%{transform:scale(.95);opacity:.85;} 50%{transform:scale(1.08);opacity:1;} }
.ai-rec-title { font-size: 14px; color: var(--teal); font-weight: 500; }
.ai-rec-body { font-size: 14px; line-height: 1.95; color: var(--text-primary); }

/* ④ 親戚説明シート */
.explain-card {
  background: var(--bg-paper);
  border: 1px solid var(--line);
  border-radius: 22px;
  padding: 30px;
}
.explain-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 14px;
  margin-bottom: 22px;
}
.explain-card-item {
  padding: 18px 20px;
  background: rgba(212,169,94,0.06);
  border: 1px solid rgba(212,169,94,0.30);
  border-radius: 14px;
}
.explain-card-title { font-size: 14px; font-weight: 500; color: var(--text-primary); margin-bottom: 8px; }
.explain-card-desc { font-size: 12px; color: var(--text-secondary); line-height: 1.85; margin-bottom: 12px; }
.explain-btn {
  background: var(--starlight); color: var(--navy); border: none;
  padding: 8px 16px; border-radius: 14px; font-family: var(--font); font-size: 12px; cursor: pointer;
}

/* ⑤ 家族自身のケア */
.fam-self-card {
  background: linear-gradient(135deg, rgba(216,138,149,0.04), var(--bg-paper));
  border: 1px solid rgba(216,138,149,0.30);
  border-radius: 22px;
  padding: 32px;
}
.fam-self-q { font-size: 17px; color: var(--text-primary); margin-bottom: 8px; font-weight: 500; }
.fam-self-sub { font-size: 13px; color: var(--text-secondary); line-height: 2; margin-bottom: 24px; }
.fam-mood-options { display: flex; gap: 10px; flex-wrap: wrap; }
.fam-mood-btn {
  padding: 12px 22px;
  background: var(--morning-white);
  border: 1px solid var(--line);
  border-radius: 22px;
  color: var(--text-primary);
  font-family: var(--font); font-size: 13.5px;
  cursor: pointer;
  transition: all 0.2s;
}
.fam-mood-btn:hover { border-color: var(--rose); color: var(--rose); }

/* ⑥ ACP */
.acp-card {
  background: linear-gradient(135deg, var(--night-medium), var(--night-deep));
  color: var(--text-on-dark);
  border-radius: 22px;
  padding: 36px;
}
.acp-title { font-size: 20px; font-weight: 400; letter-spacing: 0.04em; margin-bottom: 12px; }
.acp-sub { font-size: 13px; color: var(--text-on-dark-soft); line-height: 2; margin-bottom: 22px; }
.acp-list { display: grid; gap: 10px; }
.acp-item {
  background: rgba(248,246,240,0.06);
  border: 1px solid rgba(248,246,240,0.14);
  border-radius: 14px;
  padding: 16px 20px;
  font-size: 13.5px;
}
.acp-item strong { color: var(--starlight-strong); font-weight: 500; }
.acp-actions { margin-top: 22px; display: flex; gap: 10px; flex-wrap: wrap; }
.acp-btn {
  background: var(--starlight); color: var(--navy); border: none;
  padding: 10px 20px; border-radius: 22px; font-family: var(--font); font-size: 13px; cursor: pointer;
}
.acp-btn.outline {
  background: transparent; color: var(--text-on-dark);
  border: 1px solid rgba(248,246,240,0.30);
}

/* ⑦ 緊急 */
.urg-block {
  background: linear-gradient(135deg, rgba(184,84,80,0.04), rgba(184,84,80,0.10));
  border: 2px solid rgba(184,84,80,0.30);
  border-radius: 22px; padding: 28px 30px;
}
.urg-head { display: flex; align-items: center; gap: 14px; margin-bottom: 12px; }
.urg-icon {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--urgent-red); color: var(--morning-white);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
}
.urg-title { font-size: 16px; font-weight: 500; }
.urg-body { font-size: 13px; color: var(--text-secondary); line-height: 1.95; margin-bottom: 18px; }
.urg-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.urg-btn {
  background: var(--urgent-red); color: var(--morning-white); border: none;
  padding: 12px 22px; border-radius: 14px;
  font-family: var(--font); font-size: 13.5px; cursor: pointer;
}
.urg-btn.outline { background: transparent; color: var(--urgent-red); border: 1px solid var(--urgent-red); }

/* footer */
.footer { background: var(--navy); color: var(--text-on-dark-soft); padding: 50px 30px 80px; text-align: center; }
.footer-logo { font-size: 20px; letter-spacing: 0.28em; margin-bottom: 12px; color: var(--text-on-dark); }
.footer-row { display: flex; justify-content: center; gap: 22px; margin-bottom: 14px; flex-wrap: wrap; }
.footer-badge { display: inline-flex; align-items: center; gap: 8px; padding: 7px 14px; background: rgba(248,246,240,0.06); border: 1px solid rgba(248,246,240,0.14); border-radius: 18px; font-size: 11.5px; }

@media (max-width: 760px) {
  .header { padding: 12px 16px; }
  .hero { padding: 100px 22px 40px; }
  .hero-title { font-size: 26px; }
  .section { padding: 40px 18px; }
  .section.bg > .section-inner { padding: 0 18px; }
  .section-title { font-size: 20px; }
  .patient-head { grid-template-columns: 60px 1fr; }
  .patient-update { grid-column: 1 / -1; text-align: left; }
  .msg-card { grid-template-columns: 1fr; gap: 8px; }
}

/* === SATOI 共通リッチトースト(alert置換)=== */
#satoi-toast-host { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 9999; display: flex; flex-direction: column; gap: 10px; pointer-events: none; max-width: 92vw; }
.satoi-toast { pointer-events: auto; min-width: 280px; max-width: 480px; background: linear-gradient(135deg, rgba(11,23,54,0.96), rgba(26,37,72,0.96)); color: #F8F6F0; padding: 16px 22px 16px 18px; border-radius: 16px; box-shadow: 0 16px 40px rgba(11,23,54,0.35), 0 0 0 1px rgba(212,169,94,0.30); font-family: "Noto Sans JP", "Meiryo UI", sans-serif; font-size: 13.5px; line-height: 1.75; backdrop-filter: blur(14px); display: flex; gap: 14px; align-items: flex-start; opacity: 0; transform: translateY(20px); transition: opacity 0.4s cubic-bezier(0.4,0,0.2,1), transform 0.4s cubic-bezier(0.4,0,0.2,1); border-left: 3px solid #D4A95E; }
.satoi-toast.show { opacity: 1; transform: translateY(0); }
.satoi-toast.success { border-left-color: #14A6AB; }
.satoi-toast.info { border-left-color: #D4A95E; }
.satoi-toast.warn { border-left-color: #D4622A; }
.satoi-toast-icon { flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%; background: rgba(212,169,94,0.18); display: inline-flex; align-items: center; justify-content: center; font-size: 14px; }
.satoi-toast.success .satoi-toast-icon { background: rgba(20,166,171,0.20); }
.satoi-toast.warn .satoi-toast-icon { background: rgba(212,98,42,0.20); }
.satoi-toast-body { flex: 1; white-space: pre-line; }
.satoi-toast-body strong { color: #F0C97A; font-weight: 600; }
.satoi-toast-close { background: transparent; border: none; color: rgba(248,246,240,0.5); cursor: pointer; font-size: 18px; line-height: 1; padding: 2px 4px; }
.satoi-toast-close:hover { color: #F0C97A; }
.satoi-toast-cta { margin-top: 8px; display: inline-block; padding: 6px 14px; background: rgba(212,169,94,0.20); color: #F0C97A; border: 1px solid rgba(212,169,94,0.5); border-radius: 14px; font-size: 11.5px; cursor: pointer; transition: all 0.2s; text-decoration: none; }
.satoi-toast-cta:hover { background: #D4A95E; color: #0B1736; }
@media (max-width: 768px) {
  #satoi-toast-host { bottom: 14px; }
  .satoi-toast { min-width: auto; width: calc(100vw - 28px); padding: 14px 16px; font-size: 12.5px; }
}


/* === SATOI 共通モバイル対応(iPad/iPhone)=== */
@media (max-width: 1024px) {
  /* iPad 縦 ・ ヘッダー狭め */
  .header { padding: 14px 22px !important; }
  .section, .wrap, .container, main, .main { padding-left: 22px !important; padding-right: 22px !important; }
}
@media (max-width: 768px) {
  /* iPhone ・ 主要メトリクスをモバイル最適化 */
  html { font-size: 15px; }
  body { font-size: 15px; line-height: 1.75; }
  .header { padding: 12px 14px !important; }
  h1, .hero-title, .hero-title-l1 { font-size: clamp(24px, 6vw, 32px) !important; line-height: 1.5 !important; }
  h2, .section-title, .nbm-title, .mission-line { font-size: clamp(20px, 5vw, 28px) !important; line-height: 1.55 !important; }
  h3 { font-size: 17px !important; }
  .section, .container, .wrap, main, .main, section { padding-left: 14px !important; padding-right: 14px !important; }
  section, .section { padding-top: 50px !important; padding-bottom: 50px !important; }
  /* グリッドを1列に */
  .grid, .cards, .types-grid, .stories-grid, .forum-grid, .family-grid, .promise-list, .partner-grid, .gov-grid, .numbers-grid, .empse-grid, .pubmed-list, .sources-grid, .criteria-grid, .tx-cat-grid, .map-wrap, .emg-grid, .emg-consent-grid, .emg-contacts, .kids-talk-wrap, .cat-grid, .videos-grid, .cat-cards, .partner-cards, .promise-cards, .principle-cards, .pricing-grid, .pricing-cards, .step-cards, .info-cards, .role-cards, .news-grid {
    grid-template-columns: 1fr !important;
    gap: 14px !important;
  }
  /* 横スクロールのみ許す要素は残す */
  .b1-journey-bar, .journey-bar, .types-tabs { overflow-x: auto !important; -webkit-overflow-scrolling: touch; }
  /* ヒーローの padding 圧縮 */
  .hero { padding: 90px 14px 50px !important; min-height: auto !important; }
  /* 大きい見出し */
  .opener-line { font-size: 24px !important; margin-bottom: 40px !important; }
  /* タップ領域 44px 最低 */
  .btn, button, .login-btn, .nav-mini a, .filter-chip, .cat-card, .type-card, .story-card, .forum-card { min-height: 40px; }
  /* テーブル横スクロール */
  table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  /* マイチーム ホイール → 縦並びに */
  .team-wheel-wrap, .team-wheel { width: 100% !important; height: auto !important; min-height: 360px; }
  /* モーダル系: 画面いっぱいに */
  .modal, .overlay-modal, [class*='Modal'], [class*='modal'] { max-width: 100vw !important; }
  /* ナビ縮小 */
  .nav-mini, .nav { gap: 12px !important; font-size: 12px !important; }
  /* フォーム入力 */
  input, textarea, select { font-size: 16px !important; } /* iOSのズーム防止 */
  /* SVG レーダーチャートの収まり */
  .empse-chart, .empse-chart-wrap { width: 100% !important; max-width: 320px; height: auto !important; margin: 0 auto !important; }
  /* B1 7ステップを横スクロールに */
  .steps-row { overflow-x: auto; -webkit-overflow-scrolling: touch; gap: 10px; }
  .steps-row .step { flex-shrink: 0; min-width: 80px; }
  /* G2 サイドナビは画面下部固定 or hamburger 想定 */
  .sidebar, .side-nav, .g2-sidebar { position: relative !important; width: 100% !important; height: auto !important; overflow-x: auto !important; display: flex !important; }
}
@media (max-width: 480px) {
  /* 極小画面 */
  .hero { padding: 80px 12px 40px !important; }
  .b1-journey-bar { padding: 8px 10px !important; }
  .satoi-toast { font-size: 12px; padding: 12px 14px; }
}


/* === SATOI ユニバーサル横断ナビ(戻る/ホーム/言語) === */
#satoi-univ-nav { position: fixed; top: 50%; right: 14px; transform: translateY(-50%); z-index: 9998; display: flex; flex-direction: column; gap: 8px; pointer-events: none; }
.satoi-univ-btn { pointer-events: auto; width: 44px; height: 44px; border-radius: 50%; background: rgba(11,23,54,0.85); color: #F0C97A; border: 1px solid rgba(212,169,94,0.4); display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 16px; backdrop-filter: blur(10px); transition: all 0.3s; box-shadow: 0 6px 18px rgba(11,23,54,0.25); font-family: inherit; }
.satoi-univ-btn:hover { background: #D4A95E; color: #0B1736; transform: scale(1.1); }
.satoi-univ-btn[title]::after { content: attr(title); position: absolute; right: 54px; background: rgba(11,23,54,0.92); color: #F8F6F0; font-size: 11px; padding: 4px 10px; border-radius: 8px; white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
.satoi-univ-btn:hover::after { opacity: 1; }
.satoi-lang-pop { position: absolute; right: 54px; top: 0; background: rgba(11,23,54,0.94); border: 1px solid rgba(212,169,94,0.4); border-radius: 12px; padding: 6px; min-width: 130px; display: none; flex-direction: column; gap: 2px; box-shadow: 0 14px 30px rgba(0,0,0,0.4); }
.satoi-lang-pop.show { display: flex; }
.satoi-lang-opt { padding: 8px 14px; border-radius: 8px; color: #F8F6F0; font-size: 12px; cursor: pointer; text-align: left; background: transparent; border: none; font-family: inherit; }
