    document.addEventListener('click', (e) => { if (!langPop.contains(e.target) && e.target !== langBtn) langPop.classList.remove('show'); });
    langPop.querySelectorAll('.satoi-lang-opt').forEach(b => {
      b.addEventListener('click', () => {
        langPop.querySelectorAll('.satoi-lang-opt').forEach(x => x.classList.remove('active'));
        b.classList.add('active');
        const lang = b.dataset.lang;
        const labels = { ja: '日本語に切り替えました', en: 'Switched to English (translation coming soon)', zh: '已切换到中文(翻译即将推出)', ko: '한국어로 전환되었습니다 (번역 준비 중)' };
        if (typeof satoiNotify === 'function') satoiNotify(labels[lang] || labels.ja, { kind: 'info', duration: 3000 });
        document.documentElement.lang = lang;
        langPop.classList.remove('show');
      });
    });
  }
  if (document.body) inject();
  else document.addEventListener('DOMContentLoaded', inject);
})();

window.alert = function(msg){ try { satoiNotify(String(msg)); } catch(e){ window.__origAlert(msg); } };

(function(){
  const layer = document.getElementById('heroStars');
  if (!layer) return;
  for (let i=0; i<45; i++) {
    const s = document.createElement('div');
    s.className = 'h-star';
    const sz = Math.random()*2 + 0.6;
    s.style.width = sz + 'px'; s.style.height = sz + 'px';
    s.style.left = (Math.random()*100) + '%';
    s.style.top = (Math.random()*70) + '%';
    s.style.animationDelay = (Math.random()*5) + 's';
    s.style.animationDuration = (3 + Math.random()*2.5) + 's';
    layer.appendChild(s);
  }
})();
</script>

