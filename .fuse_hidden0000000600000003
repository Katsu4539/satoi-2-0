<script>

/* === SATOI 共通リッチトースト関数 === */
(function ensureToastHost(){
  if (document.getElementById('satoi-toast-host')) return;
  document.addEventListener('DOMContentLoaded', () => {
    if (!document.getElementById('satoi-toast-host')) {
      const host = document.createElement('div');
      host.id = 'satoi-toast-host';
      document.body.appendChild(host);
    }
  });
  if (document.body && !document.getElementById('satoi-toast-host')) {
    const host = document.createElement('div');
    host.id = 'satoi-toast-host';
    document.body.appendChild(host);
  }
})();
function satoiNotify(msg, opts) {
  opts = opts || {};
  let host = document.getElementById('satoi-toast-host');
  if (!host) { host = document.createElement('div'); host.id = 'satoi-toast-host'; document.body.appendChild(host); }
  const t = document.createElement('div');
  const kind = opts.kind || (msg.indexOf('✓')===0 ? 'success' : 'info');
  t.className = 'satoi-toast ' + kind;
  const icon = opts.icon || (kind === 'success' ? '✓' : (kind === 'warn' ? '!' : '●'));
  const body = msg.replace(/\\n/g, '\n').replace(/\n/g, '<br>');
  let html = '<span class="satoi-toast-icon">'+icon+'</span><div class="satoi-toast-body">'+body+'</div>';
  if (opts.cta && opts.href) {
    html = html.replace('</div>', '<a class="satoi-toast-cta" href="'+opts.href+'">'+opts.cta+' →</a></div>');
  }
  html += '<button class="satoi-toast-close" aria-label="close">×</button>';
  t.innerHTML = html;
  host.appendChild(t);
  requestAnimationFrame(() => t.classList.add('show'));
  const dur = opts.duration || 4200;
  const closer = () => { t.classList.remove('show'); setTimeout(()=>t.remove(), 450); };
  t.querySelector('.satoi-toast-close').addEventListener('click', closer);
  setTimeout(closer, dur);
  return t;
}
// 既存の alert を全て satoiNotify にフォールバック(他コードからのalert呼び出しもキャッチ)
window.__origAlert = window.alert;

/* === SATOI ユニバーサル横断ナビ JS === */
(function setupUnivNav(){
  function inject(){
    if (document.getElementById('satoi-univ-nav')) return;
    const nav = document.createElement('div');
    nav.id = 'satoi-univ-nav';
    nav.innerHTML = '<button class="satoi-univ-btn" id="satoi-back-btn" title="戻る" aria-label="戻る">←</button>'
      + '<button class="satoi-univ-btn" id="satoi-home-btn" title="夜空ホーム" aria-label="夜空ホーム">⌂</button>'
      + '<button class="satoi-univ-btn" id="satoi-hub-btn" title="全体マップ" aria-label="全体マップ">◎</button>'
      + '<div style="position:relative;"><button class="satoi-univ-btn" id="satoi-lang-btn" title="言語" aria-label="言語">🌐</button>'
      + '<div class="satoi-lang-pop" id="satoi-lang-pop"><button class="satoi-lang-opt active" data-lang="ja">日本語</button><button class="satoi-lang-opt" data-lang="en">English</button><button class="satoi-lang-opt" data-lang="zh">中文</button><button class="satoi-lang-opt" data-lang="ko">한국어</button></div></div>';
    document.body.appendChild(nav);
    document.getElementById('satoi-back-btn').addEventListener('click', () => { if (history.length > 1) history.back(); else location.href='SATOI_Mock_v1_A1_entrance.html'; });
    document.getElementById('satoi-home-btn').addEventListener('click', () => location.href='SATOI_Mock_v1_A1_entrance.html');
    document.getElementById('satoi-hub-btn').addEventListener('click', () => location.href='SATOI_Mock_v1_B1_hub.html');
    const conBtn = document.getElementById('satoi-con-btn'); if (conBtn) conBtn.addEventListener('click', () => location.href='SATOI_Mock_v1_CON_concierge.html');
    const langBtn = document.getElementById('satoi-lang-btn');
    const langPop = document.getElementById('satoi-lang-pop');
    langBtn.addEventListener('click', (e) => { e.stopPropagation(); langPop.classList.toggle('show'); });
    document.addEventListener('click', (e) => { if (!langPop.contains(e.target) && e.target !== langBtn) langPop.classList.remove('show'); });
    langPop.querySelectorAll('.satoi-lang-opt').forEach(b => {
      b.addEventListener('click', () => {
        langPop.querySelectorAll('.satoi-lang-opt').forEach(x => x.classList.remove('active'));
        b.classList.add('active');
        const lang = b.dataset.lang;
        const labels = { ja: '日本語に切り替えました', en: 'Switched to English (translation coming soon)', zh: '已切换到中文(翻译即将推出)', ko: '한국어로 전환되었습니다 (번역 준비 중)' };
        if (typeof satoiNotify === 'function') satoiNotify(labels[lang] || labels.ja, { kind: 'info', duration: 3000 });
        document.documentElement.lang = lang;
        langPop.classList.remove('show');
      });
    });
  }
  if (document.body) inject();
  else document.addEventListener('DOMContentLoaded', inject);
})();

window.alert = function(msg){ try { satoiNotify(String(msg)); } catch(e){ window.__origAlert(msg); } };

function openPubmed(q) {
  const url = 'https://pubmed.ncbi.nlm.nih.gov/?term=' + encodeURIComponent(q);
  window.open(url, '_blank');
}
function searchPubmed() {
  const v = document.getElementById('pubmedInput').value.trim();
  if (!v) { alert('検索キーワードを入力してください'); return; }
  openPubmed(v);
}
document.getElementById('pubmedInput').addEventListener('keydown', (e) => {
  if (e.key === 'Enter') searchPubmed();
});
// 学びの部屋「調べる」からの検索語を引き継いで入力欄に反映
(function(){
  try {
    var p = new URLSearchParams(location.search);
    var q = p.get('q') || sessionStorage.getItem('satoi_pubmed_q') || '';
    if (q) { var el = document.getElementById('pubmedInput'); if (el) el.value = q; }
  } catch(e){}
})();
</script>
