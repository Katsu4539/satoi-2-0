<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SATOI - 保険マイページ・もう、準備されています</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --night-deep: #0B1736;
  --night-medium: #1A2548;
  --dawn-pink: #D8A98A;
  --morning-cream: #F6EFE3;
  --morning-white: #FBF7F0;
  --starlight: #D4A95E;
  --starlight-soft: #E5C68A;
  --starlight-strong: #F0C97A;
  --teal: #0D7377;
  --teal-deep: #0A5A5D;
  --teal-soft: #14A6AB;
  --warm-orange: #D4622A;
  --money-green: #2D8659;
  --navy: #0A1628;
  --bg-cream: #FBF8F2;
  --bg-soft: #F4EFE6;
  --bg-paper: #FFFCF6;
  --line: rgba(10,22,40,0.10);
  --line-soft: rgba(10,22,40,0.06);
  --text-primary: #1A2A40;
  --text-secondary: rgba(26,42,64,0.72);
  --text-muted: rgba(26,42,64,0.50);
  --text-on-dark: rgba(248,246,240,0.96);
  --text-on-dark-soft: rgba(248,246,240,0.74);
  --font: "Noto Sans JP", "Meiryo UI", "Meiryo", "Hiragino Kaku Gothic ProN", sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { width:100%; min-height:100vh; overflow-x:hidden; }
body {
  font-family: var(--font);
  color: var(--text-primary);
  background: var(--morning-white);
  line-height: 1.85;
  font-size: 16px;
}

/* ヘッダー */
.header {
  position: fixed; top:0; left:0; right:0; z-index:200;
  padding: 14px 30px;
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(to bottom, rgba(11,23,54,0.92), rgba(11,23,54,0));
  backdrop-filter: blur(12px);
}
.logo {
  font-size: 22px; font-weight: 500; letter-spacing: 0.22em;
  color: var(--text-on-dark);
  display: inline-flex; align-items: center; text-decoration: none;
}
.logo .dot {
  display: inline-block; width: 8px; height: 8px;
  background: var(--starlight); border-radius: 50%;
  margin-right: 10px; box-shadow: 0 0 12px var(--starlight);
}
.header-crumb { font-size: 12px; color: var(--text-on-dark-soft); letter-spacing: 0.1em; }
.h-right { display: flex; align-items: center; gap: 10px; }
.h-link {
  color: var(--text-on-dark-soft); text-decoration: none;
  font-size: 13px; padding: 8px 14px;
  border-radius: 18px; transition: background 0.2s;
}
.h-link:hover { background: rgba(248,246,240,0.08); }
.back-btn {
  color: var(--text-on-dark-soft); text-decoration: none;
  font-size: 13px; padding: 8px 14px;
  border-radius: 18px;
  border: 1px solid rgba(248,246,240,0.22);
}

/* ヒーロー */
.hero {
  position: relative;
  padding: 110px 36px 60px;
  background: linear-gradient(180deg, var(--night-deep) 0%, var(--night-medium) 40%, var(--dawn-pink) 85%, var(--morning-cream) 100%);
  color: var(--text-on-dark);
  overflow: hidden;
}
.hero-stars { position: absolute; inset: 0; pointer-events: none; }
.h-star { position: absolute; background: var(--starlight); border-radius: 50%; opacity: 0; animation: twinkle 4.5s infinite ease-in-out; }
@keyframes twinkle { 0%,100%{opacity:.15;transform:scale(.7);} 50%{opacity:.75;transform:scale(1.1);} }

.hero-inner {
  max-width: 1100px; margin: 0 auto;
  text-align: center; position: relative; z-index: 2;
}
.hero-eyebrow {
  font-size: 12px; letter-spacing: 0.32em;
  color: var(--text-on-dark-soft); margin-bottom: 14px;
}
.hero-greet {
  font-size: 18px;
  color: var(--text-on-dark-soft);
  margin-bottom: 12px;
  font-weight: 300;
}
.hero-greet strong { color: var(--starlight-strong); font-weight: 500; }
.hero-title {
  font-size: 42px; font-weight: 300;
  letter-spacing: 0.04em; line-height: 1.35;
  color: var(--text-on-dark); margin-bottom: 18px;
}
.hero-title strong { color: var(--starlight-strong); font-weight: 500; }
.hero-sub {
  font-size: 14px;
  color: var(--text-on-dark-soft);
  line-height: 2; max-width: 660px;
  margin: 0 auto 28px;
}
.hero-stat {
  display: inline-flex; align-items: center; gap: 12px;
  padding: 12px 22px;
  background: rgba(248,246,240,0.10);
  border: 1px solid rgba(248,246,240,0.22);
  border-radius: 22px;
  font-size: 13px;
}
.hero-stat strong { color: var(--starlight-strong); font-size: 16px; font-weight: 600; }

/* セクション */
.section { max-width: 1100px; margin: 0 auto; padding: 60px 30px; }
.section.bg { background: var(--bg-cream); max-width: none; padding-left: 0; padding-right: 0; }
.section.bg > .section-inner { max-width: 1100px; margin: 0 auto; padding: 0 30px; }
.section-eyebrow { font-size: 12px; letter-spacing: 0.32em; color: var(--teal); text-transform: uppercase; margin-bottom: 10px; }
.section-title { font-size: 26px; font-weight: 400; letter-spacing: 0.04em; line-height: 1.45; margin-bottom: 12px; color: var(--text-primary); }
.section-sub { font-size: 13.5px; color: var(--text-secondary); line-height: 2; margin-bottom: 28px; max-width: 720px; }

/* ① 保険ステータス */
.policy-card {
  background: linear-gradient(135deg, var(--night-medium), var(--night-deep));
  color: var(--text-on-dark);
  border-radius: 22px;
  padding: 36px;
  position: relative;
  overflow: hidden;
}
.policy-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 20% 30%, rgba(212,169,94,0.18), transparent 50%);
  pointer-events: none;
}
.policy-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  gap: 18px;
  position: relative; z-index: 2;
}
.policy-cell {
  background: rgba(248,246,240,0.05);
  border: 1px solid rgba(248,246,240,0.12);
  border-radius: 14px;
  padding: 18px 20px;
}
.policy-label {
  font-size: 11px; letter-spacing: 0.18em;
  color: var(--starlight); margin-bottom: 8px;
}
.policy-value {
  font-size: 18px; font-weight: 500;
  color: var(--text-on-dark);
  line-height: 1.45;
}
.policy-value .yen-num {
  font-size: 26px; color: var(--starlight-strong); font-weight: 600;
}
.policy-actions {
  margin-top: 22px;
  display: flex; gap: 10px; flex-wrap: wrap;
  position: relative; z-index: 2;
}
.policy-btn {
  background: var(--starlight); color: var(--navy);
  border: none; padding: 12px 22px;
  border-radius: 22px; font-family: var(--font);
  font-size: 13px; font-weight: 500;
  cursor: pointer; transition: all 0.2s;
}
.policy-btn:hover { background: var(--starlight-strong); }
.policy-btn.outline {
  background: transparent; color: var(--text-on-dark);
  border: 1px solid rgba(248,246,240,0.4);
}
.policy-btn.outline:hover { background: rgba(248,246,240,0.08); }

/* ② ジャーニーマップ(保険版) */
.journey-card {
  background: var(--bg-paper);
  border: 1px solid var(--line);
  border-radius: 22px;
  padding: 32px;
}
.journey-stages {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 10px;
  margin-bottom: 22px;
}
.j-stage {
  background: var(--morning-white);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 16px 14px;
  text-align: center;
  cursor: pointer;
  transition: all 0.25s;
  font-family: var(--font);
  font-size: 13px;
  color: var(--text-secondary);
}
.j-stage:hover { border-color: var(--teal); color: var(--teal); transform: translateY(-2px); }
.j-stage.active {
  background: linear-gradient(135deg, var(--teal), var(--teal-soft));
  color: var(--morning-white);
  border-color: var(--teal);
  box-shadow: 0 8px 22px rgba(13,115,119,0.25);
}
.j-stage-num {
  display: block;
  font-size: 11px;
  color: var(--text-muted);
  margin-bottom: 4px;
  letter-spacing: 0.1em;
}
.j-stage.active .j-stage-num { color: rgba(248,246,240,0.7); }
.j-stage-label { font-weight: 500; line-height: 1.5; }

.journey-meta {
  margin-top: 18px;
  padding: 16px 20px;
  background: rgba(13,115,119,0.06);
  border-radius: 14px;
  font-size: 13.5px;
  color: var(--text-primary);
  line-height: 1.9;
}
.journey-meta strong { color: var(--teal); font-weight: 500; }

/* ③ AIサジェッション */
.ai-row {
  display: flex; align-items: center; gap: 14px;
  margin-bottom: 22px;
}
.ai-orb {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--starlight-strong), var(--starlight) 60%, rgba(212,169,94,0.2));
  box-shadow: 0 0 14px rgba(212,169,94,0.4);
  animation: orb-pulse 3s ease-in-out infinite;
}
@keyframes orb-pulse { 0%,100%{transform:scale(.95);opacity:.85;} 50%{transform:scale(1.08);opacity:1;} }
.ai-headline {
  font-size: 15px;
  color: var(--teal);
  font-weight: 500;
}

.priority-list { display: grid; gap: 12px; }
.priority-item {
  background: var(--bg-paper);
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 22px 26px;
  display: grid;
  grid-template-columns: 56px 1fr auto;
  gap: 22px;
  align-items: center;
  transition: all 0.2s;
  cursor: pointer;
}
.priority-item:hover { border-color: var(--teal); transform: translateY(-2px); box-shadow: 0 12px 28px rgba(10,22,40,0.06); }
.priority-num {
  width: 44px; height: 44px;
  border-radius: 50%;
  background: var(--warm-orange);
  color: var(--morning-white);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; font-weight: 600;
}
.priority-title { font-size: 15px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px; }
.priority-desc { font-size: 12.5px; color: var(--text-secondary); line-height: 1.85; }
.priority-cta {
  background: var(--teal); color: var(--morning-white);
  border: none; padding: 9px 16px;
  border-radius: 18px; font-family: var(--font);
  font-size: 12.5px; cursor: pointer;
}

/* ④ 連携医療機関 */
.facility-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 16px;
}
.facility-card {
  background: var(--bg-paper);
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 24px 22px;
  cursor: pointer;
  transition: all 0.2s;
}
.facility-card:hover { border-color: var(--teal); transform: translateY(-2px); }
.facility-eyebrow {
  font-size: 11px; letter-spacing: 0.2em;
  color: var(--teal); margin-bottom: 8px;
}
.facility-name { font-size: 15px; font-weight: 500; color: var(--text-primary); margin-bottom: 10px; line-height: 1.5; }
.facility-meta { font-size: 12px; color: var(--text-secondary); line-height: 1.85; margin-bottom: 12px; }
.facility-status {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 11px;
  background: rgba(45,134,89,0.12);
  color: var(--money-green);
  border: 1px solid var(--money-green);
}

/* ⑤ 給付金シミュレーター */
.sim-card {
  background: linear-gradient(135deg, rgba(45,134,89,0.04), var(--bg-paper));
  border: 1px solid rgba(45,134,89,0.18);
  border-radius: 22px;
  padding: 32px;
}
.sim-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  margin-bottom: 22px;
}
.sim-cell {
  background: var(--morning-white);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 18px 20px;
}
.sim-label { font-size: 11.5px; color: var(--text-muted); letter-spacing: 0.06em; margin-bottom: 6px; }
.sim-value { font-size: 22px; font-weight: 500; color: var(--text-primary); }
.sim-value.green { color: var(--money-green); }
.sim-value.orange { color: var(--warm-orange); }

.sim-bars { display: grid; gap: 10px; }
.sim-bar-row {
  display: grid;
  grid-template-columns: 140px 1fr 110px;
  align-items: center; gap: 14px;
}
.sim-bar-label { font-size: 12px; color: var(--text-secondary); }
.sim-bar-track {
  height: 24px;
  background: var(--bg-soft);
  border-radius: 12px;
  overflow: hidden;
}
.sim-bar-fill {
  height: 100%; border-radius: 12px;
  display: flex; align-items: center;
  padding-left: 12px;
  font-size: 11px; color: var(--morning-white); font-weight: 500;
  transition: width 1.2s cubic-bezier(0.4,0,0.2,1);
}
.sim-bar-fill.giving { background: var(--money-green); }
.sim-bar-fill.cost { background: var(--warm-orange); }
.sim-bar-fill.left { background: var(--teal); }
.sim-bar-num { font-size: 13px; font-weight: 500; color: var(--text-primary); text-align: right; }

/* ⑥ 家族連携 */
.family-card {
  background: var(--bg-paper);
  border: 1px solid var(--line);
  border-radius: 22px;
  padding: 32px;
}
.family-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 14px;
}
.family-item {
  background: rgba(212,169,94,0.05);
  border: 1px dashed rgba(212,169,94,0.4);
  border-radius: 14px;
  padding: 22px 20px;
  text-align: center;
}
.family-item.added {
  background: rgba(13,115,119,0.08);
  border-style: solid;
  border-color: var(--teal);
}
.family-icon {
  width: 50px; height: 50px;
  border-radius: 50%;
  background: rgba(212,169,94,0.18);
  color: var(--warm-orange);
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  margin: 0 auto 12px;
}
.family-item.added .family-icon { background: var(--teal); color: var(--morning-white); }
.family-title { font-size: 14px; font-weight: 500; margin-bottom: 8px; color: var(--text-primary); }
.family-desc { font-size: 12px; color: var(--text-secondary); line-height: 1.8; margin-bottom: 14px; }
.family-btn {
  background: transparent; color: var(--teal);
  border: 1px solid var(--teal);
  padding: 8px 18px; border-radius: 18px;
  font-family: var(--font); font-size: 12px; cursor: pointer;
}
.family-btn:hover { background: var(--teal); color: var(--morning-white); }

/* ⑦ SATOI本格利用へ */
.continue-block {
  background: linear-gradient(135deg, var(--night-medium), var(--night-deep));
  color: var(--text-on-dark);
  border-radius: 22px;
  padding: 50px 44px;
  text-align: center;
}
.continue-title {
  font-size: 24px; font-weight: 300;
  letter-spacing: 0.04em; line-height: 1.55;
  margin-bottom: 14px;
}
.continue-sub {
  font-size: 13.5px;
  color: var(--text-on-dark-soft);
  line-height: 2;
  max-width: 580px; margin: 0 auto 28px;
}
.continue-cta {
  display: inline-flex; align-items: center; gap: 12px;
  padding: 16px 36px;
  background: var(--starlight);
  color: var(--navy);
  border: none; border-radius: 30px;
  font-family: var(--font); font-size: 15px; font-weight: 500;
  cursor: pointer;
  box-shadow: 0 12px 32px rgba(212,169,94,0.32);
  letter-spacing: 0.04em;
  text-decoration: none;
}
.continue-cta:hover { transform: translateY(-2px); }

/* フッター */
.footer {
  background: var(--navy);
  color: var(--text-on-dark-soft);
  padding: 40px 30px 100px;
  text-align: center;
}
.footer-logo { font-size: 20px; letter-spacing: 0.28em; margin-bottom: 12px; color: var(--text-on-dark); }
.footer-row { display: flex; justify-content: center; gap: 22px; margin-bottom: 14px; flex-wrap: wrap; }
.footer-badge {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 7px 14px;
  background: rgba(248,246,240,0.06);
  border: 1px solid rgba(248,246,240,0.14);
  border-radius: 18px;
  font-size: 11.5px;
}

@media (max-width: 760px) {
  .header { padding: 12px 16px; }
  .hero { padding: 100px 22px 50px; }
  .hero-title { font-size: 28px; }
  .section { padding: 50px 20px; }
  .section.bg > .section-inner { padding: 0 20px; }
  .section-title { font-size: 20px; }
  .priority-item { grid-template-columns: 1fr; gap: 12px; text-align: left; }
  .sim-row { grid-template-columns: 1fr; }
  .sim-bar-row { grid-template-columns: 1fr; }
  .continue-block { padding: 36px 22px; }
}

/* === SATOI 共通リッチトースト(alert置換)=== */
#satoi-toast-host { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 9999; display: flex; flex-direction: column; gap: 10px; pointer-events: none; max-width: 92vw; }
.satoi-toast { pointer-events: auto; min-width: 280px; max-width: 480px; background: linear-gradient(135deg, rgba(11,23,54,0.96), rgba(26,37,72,0.96)); color: #F8F6F0; padding: 16px 22px 16px 18px; border-radius: 16px; box-shadow: 0 16px 40px rgba(11,23,54,0.35), 0 0 0 1px rgba(212,169,94,0.30); font-family: "Noto Sans JP", "Meiryo UI", sans-serif; font-size: 13.5px; line-height: 1.75; backdrop-filter: blur(14px); display: flex; gap: 14px; align-items: flex-start; opacity: 0; transform: translateY(20px); transition: opacity 0.4s cubic-bezier(0.4,0,0.2,1), transform 0.4s cubic-bezier(0.4,0,0.2,1); border-left: 3px solid #D4A95E; }
.satoi-toast.show { opacity: 1; transform: translateY(0); }
.satoi-toast.success { border-left-color: #14A6AB; }
.satoi-toast.info { border-left-color: #D4A95E; }
.satoi-toast.warn { border-left-color: #D4622A; }
.satoi-toast-icon { flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%; background: rgba(212,169,94,0.18); display: inline-flex; align-items: center; justify-content: center; font-size: 14px; }
.satoi-toast.success .satoi-toast-icon { background: rgba(20,166,171,0.20); }
.satoi-toast.warn .satoi-toast-icon { background: rgba(212,98,42,0.20); }
.satoi-toast-body { flex: 1; white-space: pre-line; }
.satoi-toast-body strong { color: #F0C97A; font-weight: 600; }
.satoi-toast-close { background: transparent; border: none; color: rgba(248,246,240,0.5); cursor: pointer; font-size: 18px; line-height: 1; padding: 2px 4px; }
.satoi-toast-close:hover { color: #F0C97A; }
.satoi-toast-cta { margin-top: 8px; display: inline-block; padding: 6px 14px; background: rgba(212,169,94,0.20); color: #F0C97A; border: 1px solid rgba(212,169,94,0.5); border-radius: 14px; font-size: 11.5px; cursor: pointer; transition: all 0.2s; text-decoration: none; }
.satoi-toast-cta:hover { background: #D4A95E; color: #0B1736; }
@media (max-width: 768px) {
  #satoi-toast-host { bottom: 14px; }
  .satoi-toast { min-width: auto; width: calc(100vw - 28px); padding: 14px 16px; font-size: 12.5px; }
}


/* === SATOI 共通モバイル対応(iPad/iPhone)=== */
@media (max-width: 1024px) {
  /* iPad 縦 ・ ヘッダー狭め */
  .header { padding: 14px 22px !important; }
  .section, .wrap, .container, main, .main { padding-left: 22px !important; padding-right: 22px !important; }
}
@media (max-width: 768px) {
  /* iPhone ・ 主要メトリクスをモバイル最適化 */
  html { font-size: 15px; }
  body { font-size: 15px; line-height: 1.75; }
  .header { padding: 12px 14px !important; }
  h1, .hero-title, .hero-title-l1 { font-size: clamp(24px, 6vw, 32px) !important; line-height: 1.5 !important; }
  h2, .section-title, .nbm-title, .mission-line { font-size: clamp(20px, 5vw, 28px) !important; line-height: 1.55 !important; }
  h3 { font-size: 17px !important; }
  .section, .container, .wrap, main, .main, section { padding-left: 14px !important; padding-right: 14px !important; }
  section, .section { padding-top: 50px !important; padding-bottom: 50px !important; }
  /* グリッドを1列に */
  .grid, .cards, .types-grid, .stories-grid, .forum-grid, .family-grid, .promise-list, .partner-grid, .gov-grid, .numbers-grid, .empse-grid, .pubmed-list, .sources-grid, .criteria-grid, .tx-cat-grid, .map-wrap, .emg-grid, .emg-consent-grid, .emg-contacts, .kids-talk-wrap, .cat-grid, .videos-grid, .cat-cards, .partner-cards, .promise-cards, .principle-cards, .pricing-grid, .pricing-cards, .step-cards, .info-cards, .role-cards, .news-grid {
    grid-template-columns: 1fr !important;
    gap: 14px !important;
  }
  /* 横スクロールのみ許す要素は残す */
