<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SATOI - だれに、何を見せているか(同意・プライバシー設定)</title>
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg-deep: #0B1736;
  --bg-mid: #1A2548;
  --ink: #F8F6F0;
  --ink-mid: #B8BFD0;
  --ink-light: #8893A8;
  --accent: #D4A95E;
  --accent-strong: #F0C97A;
  --teal: #14A6AB;
  --teal-deep: #0D7377;
  --warm: #D4622A;
  --green: #4CAF82;
  --line: rgba(248,246,240,0.12);
  --card: rgba(248,246,240,0.05);
  --font: 'Noto Sans JP', sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: var(--font);
  background: var(--bg-deep);
  color: var(--ink);
  line-height: 1.8;
  -webkit-font-smoothing: antialiased;
  background-image:
    radial-gradient(ellipse at 25% -5%, rgba(13,115,119,0.10), transparent 50%),
    radial-gradient(ellipse at 80% 100%, rgba(212,169,94,0.06), transparent 50%);
  background-attachment: fixed; min-height: 100vh;
}
.header {
  position: sticky; top: 0; z-index: 50;
  background: rgba(11,23,54,0.88); backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--line);
  padding: 16px 32px; display: flex; align-items: center; gap: 18px;
}
.logo { font-weight: 700; letter-spacing: 0.22em; color: var(--ink); font-size: 15px; text-decoration:none; }
.logo .dot { display:inline-block; width:8px; height:8px; background: var(--accent); border-radius: 50%; margin-right: 8px; vertical-align: middle; }
.back-link { margin-left: auto; padding: 9px 20px; background: rgba(248,246,240,0.08); border: 1px solid var(--line); border-radius: 18px; color: var(--ink); text-decoration: none; font-size: 14px; }
.back-link:hover { background: rgba(248,246,240,0.16); }

.main { max-width: 820px; margin: 0 auto; padding: 44px 24px 90px; }

.page-eyebrow { font-size: 12px; color: var(--accent-strong); letter-spacing: 0.22em; margin-bottom: 12px; }
.page-title { font-size: 32px; font-weight: 700; margin-bottom: 14px; letter-spacing: 0.04em; line-height: 1.4; }
.page-sub { color: var(--ink-mid); font-size: 16px; margin-bottom: 14px; }
.page-reassure {
  display: inline-flex; align-items: center; gap: 10px;
  background: rgba(76,175,130,0.12); border: 1px solid rgba(76,175,130,0.4);
  border-radius: 14px; padding: 12px 20px; font-size: 14.5px; color: #8FE0B5; margin-bottom: 40px;
}

/* 同意カード */
.consent-card {
  background: var(--card); border: 1px solid var(--line); border-radius: 18px;
  padding: 28px 30px; margin-bottom: 22px;
}
.consent-card-head {
  display: flex; align-items: flex-start; gap: 18px; margin-bottom: 6px;
}
.consent-icon {
  width: 54px; height: 54px; border-radius: 14px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 26px;
  background: rgba(212,169,94,0.15);
}
.consent-card-titles { flex: 1; }
.consent-title { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
.consent-desc { font-size: 14.5px; color: var(--ink-mid); line-height: 1.7; }

/* トグルスイッチ(大きく・高齢者向け) */
.toggle-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 0; border-top: 1px solid var(--line); margin-top: 18px;
}
.toggle-row:first-of-type { border-top: none; margin-top: 10px; }
.toggle-label { font-size: 16px; flex: 1; }
.toggle-label .sub { display: block; font-size: 12.5px; color: var(--ink-light); margin-top: 3px; }
.toggle-meta { font-size: 11.5px; color: var(--ink-light); margin-top: 2px; }

.switch { position: relative; display: inline-block; width: 76px; height: 40px; flex-shrink: 0; cursor: pointer; }
.switch input { opacity: 0; width: 0; height: 0; }
.slider {
  position: absolute; inset: 0; background: rgba(248,246,240,0.18);
  border-radius: 40px; transition: 0.3s;
}
.slider::before {
  content: ''; position: absolute; height: 32px; width: 32px; left: 4px; bottom: 4px;
  background: white; border-radius: 50%; transition: 0.3s;
}
.switch input:checked + .slider { background: var(--green); }
.switch input:checked + .slider::before { transform: translateX(36px); }
.switch-state { font-size: 13px; font-weight: 700; min-width: 44px; text-align: center; }
.switch-state.on { color: var(--green); }
.switch-state.off { color: var(--ink-light); }

.toggle-control { display: flex; align-items: center; gap: 12px; }

/* 家族別リスト */
.family-member {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 16px; background: rgba(248,246,240,0.03); border-radius: 12px; margin-top: 10px;
}
.family-member-info { display: flex; align-items: center; gap: 12px; }
.family-avatar { width: 40px; height: 40px; border-radius: 50%; background: rgba(20,166,171,0.2); display: flex; align-items: center; justify-content: center; font-size: 18px; }
.family-name { font-size: 15px; }
.family-rel { font-size: 12px; color: var(--ink-light); }

/* 救急開示項目 */
.disclosure-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 16px; }
.disclosure-item {
  display: flex; align-items: center; gap: 10px; padding: 14px 16px;
  background: rgba(248,246,240,0.03); border: 1px solid var(--line); border-radius: 10px;
  font-size: 14px; cursor: pointer;
}
.disclosure-item.locked { background: rgba(212,169,94,0.08); border-color: rgba(212,169,94,0.3); color: var(--accent-strong); cursor: default; }
.disclosure-item input { width: 20px; height: 20px; accent-color: var(--teal); }

/* 履歴・取り消し */
.history-note {
  background: rgba(212,98,42,0.08); border: 1px solid rgba(212,98,42,0.3);
  border-radius: 12px; padding: 16px 20px; font-size: 13.5px; color: var(--ink-mid); margin-top: 8px;
}
.revoke-link { color: var(--warm); text-decoration: underline; cursor: pointer; }

.foot-note { font-size: 12px; color: var(--ink-light); margin-top: 40px; padding-top: 20px; border-top: 1px solid var(--line); line-height: 1.8; }

/* 読み上げ・文字サイズ(高齢者向け常駐ツール) */
.access-tools {
  position: fixed; top: 80px; right: 20px; z-index: 60;
  display: flex; flex-direction: column; gap: 8px;
}
.access-btn {
  width: 50px; height: 50px; border-radius: 14px; background: rgba(11,23,54,0.9);
  border: 1px solid var(--line); color: var(--accent-strong); cursor: pointer;
  font-size: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center;
  font-family: inherit; backdrop-filter: blur(8px);
}
.access-btn:hover { border-color: var(--accent); }

@media (max-width: 700px) {
  .disclosure-grid { grid-template-columns: 1fr; }
  .page-title { font-size: 24px; }
  .access-tools { display: none; }
  .toggle-label { font-size: 15px; }
}
body.large-text { font-size: 119%; }
</style>
</head>
<body>

<header class="header">
  <a href="SATOI_Mock_v1_C1_mypage.html" class="logo"><span class="dot"></span>SATOI</a>
  <a href="SATOI_Mock_v1_C1_mypage.html" class="back-link">← マイページに戻る</a>
</header>

<!-- 高齢者向けアクセシビリティツール -->
<div class="access-tools">
  <button class="access-btn" onclick="document.body.classList.toggle('large-text')" title="文字を大きく">🔍<span style="font-size:9px;">大きく</span></button>
  <button class="access-btn" onclick="readPage()" title="読み上げる">🔊<span style="font-size:9px;">読む</span></button>
</div>

<main class="main">

  <div class="page-eyebrow">PRIVACY & CONSENT</div>
  <h1 class="page-title">だれに、何を見せているか</h1>
  <div class="page-sub">あなたの情報は、あなたのものです。<br>ここで、いつでも確認・変更できます。</div>
  <div class="page-reassure">
    <span>🔒</span>
    <span>すべての共有は、あなたが「はい」と言ったものだけ。いつでも、止められます。</span>
  </div>

  <!-- 1. 保険会社との連携 -->
  <section class="consent-card">
    <div class="consent-card-head">
      <div class="consent-icon">🏦</div>
      <div class="consent-card-titles">
        <div class="consent-title">保険会社との、つながり</div>
        <div class="consent-desc">あなたの治療状況を保険会社に伝えると、給付金の申請がスムーズになります。伝える内容は、あなたが選べます。</div>
      </div>
    </div>
    <div class="toggle-row">
      <div class="toggle-label">
        保険会社と、つながる
        <span class="sub">第一生命 がん終身保険(契約番号 12345-67890-A)</span>
        <span class="toggle-meta">同意日:2026-04-12 ・ いつでも取り消せます</span>
      </div>
      <div class="toggle-control">
        <span class="switch-state on" id="state-insurance">ON</span>
        <label class="switch"><input type="checkbox" checked data-consent="insurance"><span class="slider"></span></label>
      </div>
    </div>
    <div class="toggle-row">
      <div class="toggle-label">
        給付金の自動おしらせを受け取る
        <span class="sub">あなたが申請できる給付金を、SATOIが見つけてお知らせ</span>
      </div>
      <div class="toggle-control">
        <span class="switch-state on" id="state-benefit">ON</span>
        <label class="switch"><input type="checkbox" checked data-consent="benefit"><span class="slider"></span></label>
      </div>
    </div>
  </section>

  <!-- 2. 家族との共有 -->
  <section class="consent-card">
    <div class="consent-card-head">
      <div class="consent-icon">👨‍👩‍👧</div>
      <div class="consent-card-titles">
        <div class="consent-title">家族との、共有</div>
        <div class="consent-desc">登録した家族だけが、あなたの選んだ情報を見られます。家族ごとに、見せる・見せないを決められます。</div>
      </div>
    </div>
    <div class="family-member">
      <div class="family-member-info">
        <div class="family-avatar">👤</div>
        <div>
          <div class="family-name">配偶者</div>
          <div class="family-rel">同居家族 ・ 同意日 2026-04-15</div>
        </div>
      </div>
      <div class="toggle-control">
        <span class="switch-state on" id="state-fam1">見せる</span>
        <label class="switch"><input type="checkbox" checked data-consent="fam1"><span class="slider"></span></label>
      </div>
    </div>
    <div class="family-member">
      <div class="family-member-info">
        <div class="family-avatar">👤</div>
        <div>
          <div class="family-name">長女</div>
          <div class="family-rel">別居家族 ・ 同意日 2026-04-20</div>
        </div>
      </div>
      <div class="toggle-control">
        <span class="switch-state on" id="state-fam2">見せる</span>
        <label class="switch"><input type="checkbox" checked data-consent="fam2"><span class="slider"></span></label>
      </div>
    </div>
    <div class="toggle-row" style="border-top:1px solid var(--line); margin-top:16px;">
      <div class="toggle-label">
        新しい家族を、登録する
        <span class="sub">メールアドレスで招待 ・ 家族が自分でパスワードを設定します</span>
      </div>
      <div class="toggle-control">
        <button onclick="satoiToast('家族招待メールの送信フォームを開きます\\n\\n※ パスワードの使い回しはできません。家族が自分で設定します。')" style="padding:12px 22px; background:var(--teal-deep); color:white; border:none; border-radius:22px; font-size:14px; font-weight:600; cursor:pointer; font-family:inherit;">+ 招待する</button>
      </div>
    </div>
    <div class="history-note">
      💡 <strong>大切なこと:</strong> あなたが「言いたくないこと」は、家族にも自動では伝わりません。AIを通して家族に伝えるかどうかも、すべてあなたが決められます。
    </div>
  </section>

  <!-- 3. 救急時の開示 -->
  <section class="consent-card">
    <div class="consent-card-head">
      <div class="consent-icon">🚑</div>
      <div class="consent-card-titles">
        <div class="consent-title">救急のときに、見せる情報</div>
        <div class="consent-desc">もしもの時、救急隊や当直の先生が、あなたを守るために必要な情報です。命に関わる項目は、必ず開示されます。</div>
      </div>
    </div>
    <div class="disclosure-grid">
      <label class="disclosure-item locked"><input type="checkbox" checked disabled> 主な病気・治療歴(必須)</label>
      <label class="disclosure-item locked"><input type="checkbox" checked disabled> アレルギー(必須)</label>
      <label class="disclosure-item locked"><input type="checkbox" checked disabled> 飲んでいる薬(必須)</label>
      <label class="disclosure-item"><input type="checkbox" checked data-consent="emg-side"> 最近の副作用の記録</label>
      <label class="disclosure-item"><input type="checkbox" checked data-consent="emg-lab"> 検査の数値</label>
      <label class="disclosure-item"><input type="checkbox" checked data-consent="emg-contact"> 家族の連絡先</label>
      <label class="disclosure-item"><input type="checkbox" checked data-consent="emg-acp"> 延命・蘇生についての希望(ACP)</label>
      <label class="disclosure-item"><input type="checkbox" data-consent="emg-story"> 物語の壺(あなたの言葉・任意)</label>
    </div>
    <div style="margin-top:16px; text-align:center;">
      <a href="SATOI_Mock_v1_EMG_qr.html" style="color:var(--accent-strong); font-size:13.5px; text-decoration:underline;">→ 救急QRカードを確認する</a>
    </div>
  </section>

  <!-- 4. 研究データ提供 -->
  <section class="consent-card">
    <div class="consent-card-head">
      <div class="consent-icon">🔬</div>
      <div class="consent-card-titles">
        <div class="consent-title">研究への、協力</div>
        <div class="consent-desc">あなたの記録(名前を消した状態)が、同じ病気と向き合う次の方の役に立つことがあります。協力は任意で、いつでも止められます。</div>
      </div>
    </div>
    <div class="toggle-row">
      <div class="toggle-label">
        匿名で、研究に協力する
        <span class="sub">名前・連絡先は一切含まれません ・ 統計データとしてのみ利用</span>
        <span class="toggle-meta">未同意 ・ 任意です</span>
      </div>
      <div class="toggle-control">
        <span class="switch-state off" id="state-research">OFF</span>
        <label class="switch"><input type="checkbox" data-consent="research"><span class="slider"></span></label>
      </div>
    </div>
  </section>

  <!-- 取り消し・履歴 -->
  <section class="consent-card">
    <div class="consent-card-head">
      <div class="consent-icon">⏱</div>
      <div class="consent-card-titles">
        <div class="consent-title">同意の、履歴と取り消し</div>
        <div class="consent-desc">これまでに、いつ・何に同意したかを確認できます。すべての同意は、ここから取り消せます(動的同意)。</div>
      </div>
    </div>
    <div class="history-note">
      📋 <strong>同意の履歴:</strong><br>
      ・2026-04-12 保険会社連携に同意<br>
      ・2026-04-15 配偶者との共有に同意<br>
      ・2026-04-20 長女との共有に同意<br>
      <br>
      <span class="revoke-link" onclick="revokeAll()">⚠ すべての共有を、いったん止める(あとで再開できます)</span>
    </div>
  </section>

  <div class="foot-note">
    SATOIは、あなたの同意なしに情報を共有することは、決してありません。<br>
    すべての共有は「動的同意」— あなたがいつでも、その場で変更・取り消しできる仕組みです。<br>
    機微情報の取り扱いは、個人情報保護法・金融庁ガイドラインに基づいています。
  </div>

</main>

<!-- トースト -->
<div id="toast-host" style="position:fixed; bottom:30px; left:50%; transform:translateX(-50%); z-index:9999; display:flex; flex-direction:column; gap:10px; pointer-events:none;"></div>

<script>
// トグル状態の保存・反映(LocalStorage)
function loadConsents() {
  let saved = {};
  try { saved = JSON.parse(localStorage.getItem('satoi_consents') || '{}'); } catch(e){}
  document.querySelectorAll('input[data-consent]').forEach(inp => {
    const key = inp.dataset.consent;
    if (saved[key] !== undefined) inp.checked = saved[key];
    updateStateLabel(inp);
  });
}
function saveConsent(inp) {
  let saved = {};
  try { saved = JSON.parse(localStorage.getItem('satoi_consents') || '{}'); } catch(e){}
  saved[inp.dataset.consent] = inp.checked;
  try { localStorage.setItem('satoi_consents', JSON.stringify(saved)); } catch(e){}
}
function updateStateLabel(inp) {
  const map = {
    'insurance': 'state-insurance', 'benefit': 'state-benefit',
    'fam1': 'state-fam1', 'fam2': 'state-fam2', 'research': 'state-research'
  };
  const id = map[inp.dataset.consent];
  if (!id) return;
  const el = document.getElementById(id);
  if (!el) return;
  const onText = (inp.dataset.consent === 'fam1' || inp.dataset.consent === 'fam2') ? '見せる' : 'ON';
  const offText = (inp.dataset.consent === 'fam1' || inp.dataset.consent === 'fam2') ? '見せない' : 'OFF';
  el.textContent = inp.checked ? onText : offText;
  el.className = 'switch-state ' + (inp.checked ? 'on' : 'off');
}

document.querySelectorAll('input[data-consent]').forEach(inp => {
  inp.addEventListener('change', () => {
    updateStateLabel(inp);
    saveConsent(inp);
    const label = inp.closest('.toggle-row, .family-member, .disclosure-item');
    const name = label ? (label.querySelector('.toggle-label, .family-name')?.textContent || '設定').trim().split('\n')[0] : '設定';
    satoiToast((inp.checked ? '✓ ' : '○ ') + name.slice(0,20) + ' を ' + (inp.checked ? 'ONにしました' : 'OFFにしました'));
  });
});

function revokeAll() {
  if (!confirm('すべての共有を、いったん止めますか?\n\n(あとで、いつでも再開できます)')) return;
  document.querySelectorAll('input[data-consent]:not([disabled])').forEach(inp => {
    inp.checked = false;
    updateStateLabel(inp);
    saveConsent(inp);
  });
  satoiToast('すべての共有を、いったん止めました。いつでも再開できます。');
}

function satoiToast(msg) {
  const host = document.getElementById('toast-host');
  const t = document.createElement('div');
  t.style.cssText = 'background:rgba(11,23,54,0.96); border:1px solid rgba(212,169,94,0.5); border-radius:14px; padding:14px 22px; color:#F8F6F0; font-size:14px; box-shadow:0 10px 30px rgba(0,0,0,0.4); pointer-events:auto; max-width:90vw; white-space:pre-line;';
  t.textContent = msg;
  host.appendChild(t);
  setTimeout(() => { t.style.opacity = '0'; t.style.transition = '0.4s'; setTimeout(() => t.remove(), 400); }, 3000);
}

function readPage() {
  if (!('speechSynthesis' in window)) { satoiToast('お使いのブラウザは読み上げに対応していません'); return; }
  window.speechSynthesis.cancel();
  const text = document.querySelector('.page-title').textContent + '。' + document.querySelector('.page-sub').textContent + '。すべての共有は、あなたが「はい」と言ったものだけです。いつでも、止められます。';
  const u = new SpeechSynthesisUtterance(text);
  u.lang = 'ja-JP'; u.rate = 0.9;
  window.speechSynthesis.speak(u);
}

loadConsents();
</script>

<script src="satoi_common.js"></script>
</body>
</html>
