<script>

function satoiNotify(msg, opts) {
  opts = opts || {};
  let host = document.getElementById('satoi-toast-host');
  if (!host) { host = document.createElement('div'); host.id = 'satoi-toast-host'; document.body.appendChild(host); }
  const t = document.createElement('div');
  const kind = opts.kind || (msg.indexOf('✓')===0 ? 'success' : 'info');
  t.className = 'satoi-toast ' + kind;
  const icon = opts.icon || (kind === 'success' ? '✓' : (kind === 'warn' ? '!' : '●'));
  const body = msg.replace(/\n/g, '<br>');
  t.innerHTML = '<span class="satoi-toast-icon">'+icon+'</span><div class="satoi-toast-body">'+body+'</div><button class="satoi-toast-close">×</button>';
  host.appendChild(t);
  requestAnimationFrame(() => t.classList.add('show'));
  const closer = () => { t.classList.remove('show'); setTimeout(()=>t.remove(), 450); };
  t.querySelector('.satoi-toast-close').addEventListener('click', closer);
  setTimeout(closer, opts.duration || 4200);
}
window.__origAlert = window.alert;
window.alert = function(msg){ try { satoiNotify(String(msg)); } catch(e){ window.__origAlert(msg); } };
(function setupUnivNav(){
  function inject(){
    if (document.getElementById('satoi-univ-nav')) return;
    const nav = document.createElement('div'); nav.id = 'satoi-univ-nav';
    nav.innerHTML = '<button class="satoi-univ-btn" title="戻る">←</button><button class="satoi-univ-btn" title="夜空ホーム">⌂</button><button class="satoi-univ-btn" title="全体マップ">◎</button><button class="satoi-univ-btn" title="コンシェルジュ">💬</button><div style="position:relative;"><button class="satoi-univ-btn" title="言語">🌐</button><div class="satoi-lang-pop"><button class="satoi-lang-opt active" data-lang="ja">日本語</button><button class="satoi-lang-opt" data-lang="en">English</button><button class="satoi-lang-opt" data-lang="zh">中文</button><button class="satoi-lang-opt" data-lang="ko">한국어</button></div></div>';
    document.body.appendChild(nav);
    const btns = nav.querySelectorAll('.satoi-univ-btn');
    btns[0].addEventListener('click', () => { if (history.length > 1) history.back(); else location.href='SATOI_Mock_v1_A1_entrance.html'; });
    btns[1].addEventListener('click', () => location.href='SATOI_Mock_v1_A1_entrance.html');
    btns[2].addEventListener('click', () => location.href='SATOI_Mock_v1_B1_hub.html');
    btns[3].addEventListener('click', () => location.href='SATOI_Mock_v1_CON_concierge.html');
    const langBtn = btns[4]; const langPop = nav.querySelector('.satoi-lang-pop');
    langBtn.addEventListener('click', (e) => { e.stopPropagation(); langPop.classList.toggle('show'); });
    document.addEventListener('click', (e) => { if (!langPop.contains(e.target) && e.target !== langBtn) langPop.classList.remove('show'); });
    langPop.querySelectorAll('.satoi-lang-opt').forEach(b => { b.addEventListener('click', () => {
      langPop.querySelectorAll('.satoi-lang-opt').forEach(x => x.classList.remove('active')); b.classList.add('active');
      const labels = { ja: '日本語', en: 'English (translation coming)', zh: '中文 (即将推出)', ko: '한국어 (준비 중)' };
      satoiNotify('言語を ' + labels[b.dataset.lang] + ' に切り替えました', { duration: 2400 });
      document.documentElement.lang = b.dataset.lang; langPop.classList.remove('show');
    }); });
  }
  if (document.body) inject(); else document.addEventListener('DOMContentLoaded', inject);
})();

function startChat() {
  document.getElementById('chatWrap').classList.add('show');
  document.getElementById('chatWrap').scrollIntoView({ behavior: 'smooth' });
  setTimeout(() => document.getElementById('chatInput').focus(), 600);
}

function useQuick(btn) {
  document.getElementById('chatInput').value = btn.textContent;
  startChat();
  setTimeout(() => sendChat(), 200);
}

function appendMsg(text, type) {
  const wrap = document.getElementById('chatHistory');
  const div = document.createElement('div');
  div.className = 'chat-msg chat-msg-' + type;
  const initial = type === 'ai' ? 'S' : 'あ';
  div.innerHTML = '<div class="chat-avatar">' + initial + '</div><div class="chat-bubble">' + text + '</div>';
  wrap.appendChild(div);
  wrap.scrollTop = wrap.scrollHeight;
}

function sendChat() {
  const input = document.getElementById('chatInput');
  const txt = input.value.trim();
  if (!txt) return;
  appendMsg(txt, 'user');
  input.value = '';
  // AI返答シミュレーション
  setTimeout(() => {
    let reply = '';
    if (/告知|診断|頭が真っ白|何も考え/.test(txt)) {
      reply = 'そうですよね。告知のあと、何も考えられないのは、ごく自然なことです。<br>同じ気持ちを抱えた方が、たくさんここにいます。<br><br>もし「もう少し落ち着いて話したい」と思ったら、<a href="tel:0120-1234-5678" style="color:#F0C97A;">📞 電話</a> もできます。';
    } else if (/家族|伝え|子供|親/.test(txt)) {
      reply = '大切な人にどう伝えるか、悩みますよね。<br>子供への伝え方は、年齢で言葉が変わります。<br><a href="SATOI_Mock_v1_B1_hub.html?section=kids&from=concierge" style="color:#F0C97A;">→ 子供への伝え方ガイド</a> にも、参考例があります。';
    } else if (/仕事|会社|休職|両立/.test(txt)) {
      reply = '仕事のことは、多くの方が最初に悩まれます。<br>傷病手当金・治療と仕事の両立支援制度、社労士相談など、お金・制度のページにまとまっています。<br><a href="SATOI_Mock_v1_E1_money.html?from=concierge" style="color:#F0C97A;">→ E1 お金・仕事の制度</a>';
    } else if (/お金|費用|高額|保険/.test(txt)) {
      reply = 'お金は、最初の心配ごとの上位です。<br>高額療養費・傷病手当金・がん保険給付、AIが「使える制度」を自動で整理します。<br><a href="SATOI_Mock_v1_E1_money.html?from=concierge" style="color:#F0C97A;">→ 制度マッチング</a>';
    } else if (/セカンド/.test(txt)) {
      reply = 'セカンドオピニオンは、患者さんの権利です。<br>主治医と関係を壊さない聞き方も、SATOI がサポートします。<br><a href="SATOI_Mock_v1_B3_treatment_detail.html?from=concierge" style="color:#F0C97A;">→ 治療詳細とSDM質問カード</a>';
    } else if (/うまく言葉|わからない|言葉にできない/.test(txt)) {
      reply = 'うまく言葉にできない、ということを、伝えてくれてありがとうございます。<br>それでも大丈夫です。SATOI は、何も決めない夜を、そばで支える存在です。<br>音声で話すと、もう少し楽な時もあります。マイクボタンを押して、ためしてみますか?';
    } else {
      reply = 'お話、ありがとうございます。<br>「' + txt + '」、ゆっくり受け止めました。<br>もう少し、詳しく聞かせてもらえますか? もしくは、電話で話すこともできます。<br><a href="tel:0120-1234-5678" style="color:#F0C97A;">📞 0120-1234-5678</a>';
    }
    appendMsg(reply, 'ai');
  }, 900);
}

document.getElementById('chatSend').addEventListener('click', sendChat);
document.getElementById('chatInput').addEventListener('keydown', (e) => {
  if (e.key === 'Enter') sendChat();
});

// 音声入力
document.getElementById('chatMic').addEventListener('click', () => {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) {
    if (typeof satoiNotify === 'function') satoiNotify('お使いのブラウザは音声入力に対応していません。Chrome/Edge をお試しください。', {kind:'warn'});
    return;
  }
  const r = new SR();
  r.lang = 'ja-JP';
  r.onresult = (e) => {
    let txt = '';
    for (let i = 0; i < e.results.length; i++) txt += e.results[i][0].transcript;
    document.getElementById('chatInput').value = txt;
    if (e.results[0].isFinal) setTimeout(sendChat, 500);
  };
  r.start();
});
</script>
