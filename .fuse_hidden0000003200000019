      </div>
    </div>
    <div class="chat-input-row">
      <button class="chat-mic" id="chatMic" aria-label="音声入力">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 11 v1 a7 7 0 0 0 14 0 v-1"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="8" y1="22" x2="16" y2="22"/></svg>
