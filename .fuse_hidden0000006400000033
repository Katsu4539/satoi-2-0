<style>
:root {
  --night-deep: #0B1736;
  --night-medium: #1A2548;
  --starlight: #D4A95E;
  --starlight-soft: #E5C68A;
  --starlight-strong: #F0C97A;
  --teal: #0D7377;
  --teal-soft: #14A6AB;
  --teal-deep: #0A5A5D;
  --warm-orange: #D4622A;
  --rose: #C76B7F;
  --text-on-dark: rgba(248,246,240,0.96);
  --text-on-dark-soft: rgba(248,246,240,0.78);
  --text-on-dark-quiet: rgba(248,246,240,0.55);
  --line: rgba(248,246,240,0.10);
  --font: "Noto Sans JP", "Meiryo UI", "Meiryo", "Hiragino Kaku Gothic ProN", sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { width:100%; overflow-x:hidden; }
body {
  font-family: var(--font);
  color: var(--text-on-dark);
  background: radial-gradient(ellipse at top, #0F2A2D 0%, var(--night-deep) 60%, #060d1f 100%);
  background-attachment: fixed;
  line-height: 2;
  font-weight: 300;
  min-height: 100vh;
  padding-bottom: 120px;
}
.stars-layer { position: fixed; inset: 0; z-index: -1; pointer-events: none; overflow: hidden; }
.star { position: absolute; background: var(--teal-soft); border-radius: 50%; opacity: 0; animation: twinkle 5s infinite ease-in-out; }
@keyframes twinkle { 0%,100% { opacity:0.1; transform:scale(0.7);} 50% { opacity:0.6; transform:scale(1.1);} }

.header { position: fixed; top:0; left:0; right:0; z-index:100; padding: 18px 36px; display:flex; align-items:center; justify-content:space-between; background: linear-gradient(to bottom, rgba(11,23,54,0.7), rgba(11,23,54,0)); backdrop-filter: blur(10px); }
.logo { font-size: 22px; font-weight: 500; letter-spacing: 0.22em; color: var(--text-on-dark); text-decoration: none; display: inline-flex; align-items: center; }
.logo .dot { display:inline-block; width:8px; height:8px; background: var(--teal-soft); border-radius:50%; margin: 0 10px 0 0; box-shadow: 0 0 12px var(--teal-soft); }
.header-nav { display:flex; gap: 22px; }
.header-nav a { color: var(--text-on-dark-soft); font-size: 12.5px; text-decoration: none; letter-spacing: 0.12em; transition: color 0.2s; }
.header-nav a:hover { color: var(--teal-soft); }

.hero { padding: 160px 24px 80px; text-align: center; max-width: 920px; margin: 0 auto; }
.hero-eyebrow { font-size: 11px; letter-spacing: 0.42em; color: var(--teal-soft); margin-bottom: 22px; }
.hero-title { font-size: clamp(38px, 6.5vw, 68px); font-weight: 200; line-height: 1.2; margin-bottom: 28px; letter-spacing: 0.06em; }
.hero-title .accent { color: var(--teal-soft); font-weight: 300; }
.hero-sub { font-size: clamp(15px, 1.6vw, 18px); color: var(--text-on-dark-soft); font-weight: 300; max-width: 680px; margin: 0 auto; letter-spacing: 0.04em; }

.section { max-width: 920px; margin: 60px auto; padding: 0 24px; }
.section-title { font-size: 13px; letter-spacing: 0.32em; color: var(--teal-soft); margin-bottom: 16px; }
.section-heading { font-size: clamp(24px, 3.5vw, 36px); font-weight: 300; line-height: 1.5; margin-bottom: 28px; letter-spacing: 0.04em; }
.section-body { font-size: 15px; line-height: 2.1; color: var(--text-on-dark-soft); font-weight: 300; }
.section-body p { margin-bottom: 20px; }
.section-body strong { color: var(--teal-soft); font-weight: 500; }

/* === マイチームのビジュアル === */
.team-wheel {
  position: relative;
  width: 100%; max-width: 500px;
  aspect-ratio: 1;
  margin: 50px auto;
}
.team-center {
  position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  width: 110px; height: 110px;
  background: radial-gradient(circle, var(--teal-soft), var(--teal-deep));
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-direction: column;
  color: var(--text-on-dark);
  font-size: 13px; letter-spacing: 0.12em;
  box-shadow: 0 0 60px rgba(20,166,171,0.5);
}
.team-center .me { font-size: 18px; font-weight: 400; }
.team-node {
  position: absolute;
  width: 90px; height: 90px;
  background: rgba(11,23,54,0.8);
  border: 1.5px solid rgba(20,166,171,0.5);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-direction: column;
  font-size: 11px; letter-spacing: 0.1em;
  text-align: center;
  color: var(--text-on-dark);
  backdrop-filter: blur(6px);
  transition: all 0.4s;
  animation: float 6s infinite ease-in-out;
}
.team-node:hover { border-color: var(--teal-soft); transform: scale(1.1); }
.team-node .role { font-size: 10px; color: var(--text-on-dark-quiet); margin-top: 4px; }
.team-node .icon { font-size: 22px; margin-bottom: 2px; }
@keyframes float { 0%,100% { transform: translateY(0);} 50% { transform: translateY(-6px);} }

.team-node.n1 { top: 4%; left: 50%; transform: translateX(-50%); animation-delay: 0s; }
.team-node.n2 { top: 24%; right: 4%; animation-delay: 0.8s; }
.team-node.n3 { bottom: 24%; right: 4%; animation-delay: 1.6s; }
.team-node.n4 { bottom: 4%; left: 50%; transform: translateX(-50%); animation-delay: 2.4s; }
.team-node.n5 { bottom: 24%; left: 4%; animation-delay: 3.2s; }
.team-node.n6 { top: 24%; left: 4%; animation-delay: 4s; }

.team-svg {
  position: absolute; inset: 0; width: 100%; height: 100%;
  pointer-events: none;
}
.team-svg line { stroke: rgba(20,166,171,0.25); stroke-width: 1; stroke-dasharray: 3 4; }

/* === 役割カード === */
.roles-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 16px; margin-top: 36px;
}
.role-card {
  background: rgba(248,246,240,0.04);
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 24px 22px;
  transition: all 0.3s;
}
.role-card:hover {
  border-color: rgba(20,166,171,0.4);
  transform: translateY(-3px);
}
.role-card .role-icon {
  font-size: 28px; margin-bottom: 10px;
}
.role-card h4 { font-size: 17px; font-weight: 400; margin-bottom: 8px; letter-spacing: 0.04em; }
.role-card .when { font-size: 11px; letter-spacing: 0.2em; color: var(--teal-soft); margin-bottom: 10px; }
.role-card p { font-size: 13px; line-height: 1.9; color: var(--text-on-dark-soft); font-weight: 300; }

/* === 同意フロー === */
.consent-flow {
  background: rgba(13,115,119,0.08);
  border: 1px solid rgba(20,166,171,0.3);
  border-radius: 18px;
  padding: 36px 32px;
  margin: 40px 0;
}
.consent-flow h4 { font-size: 18px; font-weight: 400; margin-bottom: 24px; letter-spacing: 0.04em; color: var(--teal-soft); }
.consent-steps {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 14px;
}
.consent-step {
  padding: 18px;
  background: rgba(11,23,54,0.5);
  border-radius: 12px;
  position: relative;
}
.consent-step .step-num {
  display: inline-block;
  width: 24px; height: 24px; line-height: 24px;
  background: var(--teal-soft); color: var(--night-deep);
  border-radius: 50%; text-align: center;
  font-size: 12px; font-weight: 500;
  margin-bottom: 10px;
}
.consent-step h5 { font-size: 14px; font-weight: 500; margin-bottom: 8px; }
.consent-step p { font-size: 12px; color: var(--text-on-dark-soft); line-height: 1.8; }

/* === 実装例 === */
.example-block {
  background: rgba(11,23,54,0.6);
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 32px 30px;
  margin: 32px 0;
}
.example-block .ex-eyebrow { font-size: 11px; letter-spacing: 0.3em; color: var(--teal-soft); margin-bottom: 14px; }
.example-block h4 { font-size: 20px; font-weight: 400; margin-bottom: 18px; }
.example-block .ex-body { font-size: 14px; color: var(--text-on-dark-soft); line-height: 2; font-weight: 300; }
.example-block .ex-cta {
  display: inline-flex; align-items: center; gap: 10px;
  margin-top: 20px; padding: 10px 22px;
  background: rgba(20,166,171,0.14);
  border: 1px solid var(--teal-soft);
  border-radius: 24px;
  color: var(--teal-soft);
  font-size: 12.5px; text-decoration: none;
  letter-spacing: 0.1em; transition: all 0.3s;
}
.example-block .ex-cta:hover { background: rgba(20,166,171,0.28); transform: translateX(4px); }

/* === 関連 === */
.related {
  max-width: 920px; margin: 80px auto 40px;
  padding: 0 24px;
  display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 14px;
}
.related a {
  display: block;
  background: rgba(248,246,240,0.04);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 18px 20px;
  color: var(--text-on-dark);
  text-decoration: none; transition: all 0.3s;
}
.related a:hover { border-color: var(--teal-soft); background: rgba(20,166,171,0.08); }
.related a .r-eyebrow { font-size: 10.5px; letter-spacing: 0.3em; color: var(--teal-soft); margin-bottom: 6px; }
.related a .r-title { font-size: 15px; letter-spacing: 0.04em; }
.related a .r-sub { font-size: 12px; color: var(--text-on-dark-soft); margin-top: 6px; }

/* === ユニバーサルナビ === */
.uninav { position: fixed; right: 22px; bottom: 100px; z-index: 90; display: flex; flex-direction: column; gap: 12px; }
.uninav a {
  width: 48px; height: 48px;
  background: rgba(11,23,54,0.85);
  border: 1px solid var(--teal-soft);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: var(--teal-soft); text-decoration: none; font-size: 18px;
  transition: all 0.3s; backdrop-filter: blur(8px);
  position: relative;
}
.uninav a:hover { background: var(--teal-soft); color: var(--night-deep); transform: scale(1.1); }
.uninav a .label {
  position: absolute; right: 56px;
  font-size: 11px; letter-spacing: 0.2em;
  background: rgba(11,23,54,0.95);
  padding: 4px 10px; border-radius: 4px;
  opacity: 0; pointer-events: none; transition: opacity 0.2s;
  white-space: nowrap; color: var(--text-on-dark);
}
.uninav a:hover .label { opacity: 1; }

.footer { text-align: center; padding: 40px 24px; font-size: 11px; letter-spacing: 0.22em; color: var(--text-on-dark-quiet); }

@media (max-width: 700px) {
  .header { padding: 14px 18px; }
  .header-nav { gap: 12px; }
  .header-nav a { font-size: 11px; }
  .hero { padding: 130px 18px 60px; }
  .team-wheel { max-width: 360px; }
  .team-node { width: 72px; height: 72px; font-size: 10px; }
  .uninav { right: 12px; bottom: 80px; }
  .uninav a { width: 42px; height: 42px; font-size: 16px; }
}
</style>
