<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SATOI - 前回の続き</title>
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg-deep: #0B1736;
  --bg-mid: #1A2548;
  --ink-on-dark: #F8F6F0;
  --ink-mid: #B8BFD0;
  --ink-light: #8893A8;
  --accent: #D4A95E;
  --accent-strong: #F0C97A;
  --teal: #14A6AB;
  --warm: #D4622A;
  --line: rgba(248,246,240,0.12);
  --card: rgba(248,246,240,0.05);
  --font: 'Noto Sans JP', sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: var(--font);
  background: var(--bg-deep);
  color: var(--ink-on-dark);
  line-height: 1.8; -webkit-font-smoothing: antialiased;
  background-image:
    radial-gradient(ellipse at 20% -10%, rgba(212,98,42,0.10), transparent 50%),
    radial-gradient(ellipse at 80% 100%, rgba(212,169,94,0.08), transparent 50%);
  background-attachment: fixed; min-height: 100vh;
}
.header {
  position: sticky; top: 0; z-index: 50;
  background: rgba(11,23,54,0.88); backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--line);
  padding: 16px 32px; display: flex; align-items: center; gap: 18px;
}
.logo { font-weight: 700; letter-spacing: 0.22em; color: var(--ink-on-dark); font-size: 15px; text-decoration:none; }
.logo .dot { display:inline-block; width:8px; height:8px; background: var(--accent); border-radius: 50%; margin-right: 8px; vertical-align: middle; }
.back-link { margin-left: auto; padding: 8px 18px; background: rgba(248,246,240,0.08); border: 1px solid var(--line); border-radius: 18px; color: var(--ink-on-dark); text-decoration: none; font-size: 13px; }

.main { max-width: 760px; margin: 0 auto; padding: 50px 28px 80px; }

.greet-eyebrow { font-size: 11.5px; color: var(--accent-strong); letter-spacing: 0.22em; margin-bottom: 12px; }
.greet-title { font-size: 32px; font-weight: 700; margin-bottom: 18px; letter-spacing: 0.04em; line-height: 1.4; }
.greet-sub { color: var(--ink-mid); font-size: 15px; margin-bottom: 36px; }

/* 上段:前回の振り返り(ブログ風) */
.recap-section {
  background: linear-gradient(135deg, rgba(212,169,94,0.10), rgba(212,98,42,0.08));
  border: 1px solid rgba(212,169,94,0.3);
  border-radius: 20px;
  padding: 30px 32px; margin-bottom: 26px;
}
.recap-eyebrow { font-size: 11.5px; color: var(--accent-strong); letter-spacing: 0.18em; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
.recap-eyebrow-icon { font-size: 16px; }
.recap-title { font-size: 19px; font-weight: 700; margin-bottom: 14px; color: var(--ink-on-dark); }
.recap-body { color: var(--ink-on-dark); font-size: 15px; line-height: 1.95; white-space: pre-wrap; min-height: 80px; }
.recap-body.loading { color: var(--ink-light); font-style: italic; }
.recap-empty { color: var(--ink-light); font-size: 14px; font-style: italic; padding: 14px 0; }
.recap-gen-btn {
  margin-top: 16px; padding: 12px 22px; background: rgba(212,169,94,0.18); color: var(--accent-strong);
  border: 1px solid var(--accent); border-radius: 22px; cursor: pointer; font-size: 13px; font-weight: 600;
  font-family: inherit;
}
.recap-gen-btn:hover { background: rgba(212,169,94,0.3); }

/* 下段:今日は何から? */
.today-section {
  background: var(--card); border: 1px solid var(--line); border-radius: 20px;
  padding: 30px 32px;
}
.today-eyebrow { font-size: 11.5px; color: var(--teal); letter-spacing: 0.18em; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
.today-title { font-size: 19px; font-weight: 700; margin-bottom: 18px; }

.today-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.today-card {
  display: block; padding: 22px 22px; background: rgba(248,246,240,0.06); border: 1px solid var(--line);
  border-radius: 14px; text-decoration: none; color: var(--ink-on-dark); cursor: pointer;
  transition: all 0.2s;
}
.today-card:hover { background: rgba(212,169,94,0.10); border-color: var(--accent); transform: translateY(-2px); }
.today-card-icon { font-size: 26px; margin-bottom: 10px; }
.today-card-title { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
.today-card-desc { font-size: 12.5px; color: var(--ink-light); }

.start-btn {
  display: block; margin: 28px auto 0; padding: 18px 36px;
  background: var(--warm); color: white; border: none; border-radius: 32px;
  font-size: 16px; font-weight: 700; cursor: pointer; font-family: inherit;
  box-shadow: 0 8px 24px rgba(212,98,42,0.4); letter-spacing: 0.06em;
  text-decoration: none; text-align: center;
}
.start-btn:hover { background: #B85420; transform: translateY(-1px); }

@media (max-width: 700px) {
  .today-cards { grid-template-columns: 1fr; }
  .greet-title { font-size: 24px; }
}
</style>
</head>
<body>

<header class="header">
  <a href="SATOI_Mock_v1_C1_mypage.html" class="logo"><span class="dot"></span>SATOI</a>
  <a href="SATOI_Mock_v1_C1_mypage.html" class="back-link">★ マイページに戻る</a>
</header>

<main class="main">

  <div class="greet-eyebrow">WELCOME BACK</div>
  <h1 class="greet-title">おかえりなさい。<br>今日も、ゆっくり始めましょう。</h1>
  <div class="greet-sub">まずは、前回までの歩みを、見てみますか?</div>

  <!-- 上段:前回までの振り返り(ブログ風) -->
  <section class="recap-section">
    <div class="recap-eyebrow"><span class="recap-eyebrow-icon">📖</span> 前回、こんなお話をしました</div>
    <h2 class="recap-title" id="recapTitle">あなたの「これまで」</h2>
    <div class="recap-body loading" id="recapBody">あなたの直近の歩みを、AIが、ゆっくり振り返っています…</div>
    <button class="recap-gen-btn" id="recapGenBtn" onclick="generateRecap()">🔄 振り返りを生成</button>
  </section>

  <!-- 下段:今日は何から? -->
  <section class="today-section">
    <div class="today-eyebrow">今日は、何から始めましょうか</div>
    <h2 class="today-title">気になることから、選んでください</h2>
    <div class="today-cards">
      <a class="today-card" href="SATOI_Mock_v1_A2_dialog.html?resume=1&cancer=breast&stage=II&from=resume_bridge">
        <div class="today-card-icon">💬</div>
        <div class="today-card-title">AIと、自由に話す</div>
        <div class="today-card-desc">今日の気持ち、悩み、なんでも</div>
      </a>
      <a class="today-card" href="SATOI_Mock_v1_F4_side_effects.html?from=resume_bridge">
        <div class="today-card-icon">🌡</div>
        <div class="today-card-title">副作用を記録する</div>
        <div class="today-card-desc">今日の体調を残す</div>
      </a>
      <a class="today-card" href="SATOI_Mock_v1_DASHBOARD.html?cancer=breast&stage=II&phase=treating">
        <div class="today-card-icon">📊</div>
        <div class="today-card-title">状況を、もう一度見る</div>
        <div class="today-card-desc">ダッシュボードで全体把握</div>
      </a>
      <a class="today-card" href="SATOI_Mock_v1_C1_review.html">
        <div class="today-card-icon">📖</div>
        <div class="today-card-title">今日の歩みを、見る</div>
        <div class="today-card-desc">行動ログのタイムライン</div>
      </a>
    </div>
    <a class="start-btn" id="startTalkBtn" href="SATOI_Mock_v1_A2_dialog.html?resume=1&cancer=breast&stage=II&from=resume_bridge">前回の続きから、AIと話す →</a>
  </section>

</main>

<script src="satoi_common.js"></script>
<script src="satoi_chat_api.js"></script>
<script>
async function generateRecap() {
  const btn = document.getElementById('recapGenBtn');
  const body = document.getElementById('recapBody');
  if (!window.satoiChatApi) {
    body.classList.remove('loading');
    body.textContent = 'AI連携モジュールが読み込まれていません。';
    return;
  }
  // 直近の行動ログを取得(複数日)
  const log = window.satoiLog ? window.satoiLog.read() : [];
  if (!log.length) {
    body.classList.remove('loading');
    body.innerHTML = `<div class="recap-empty">まだ、振り返るほどの歩みが、記録されていません。<br>SATOIの画面をいくつか歩いてみてから、また来てください。</div>`;
    return;
  }
  btn.disabled = true; btn.textContent = 'AI生成中…';
  body.classList.add('loading');
  body.textContent = '前回までのあなたの歩みを、AIが、ゆっくり読み返しています…';

  try {
    const compact = log.slice(-80).map(e => ({
      time: new Date(e.ts).toISOString().slice(0,16).replace('T',' '),
      type: e.type,
      page: e.page,
      title: e.title || e.text || ''
    }));
    const system = `あなたは SATOI のAIです。下記は、がん患者ご本人が SATOI 上で歩いた行動ログ(直近)です。
これを読んで、ご本人へ「前回までのあなたの歩み」をブログ風に温かく振り返ってください(250〜400文字)。

【書き方】
- 3〜5段落。語りかけるトーン。
- 「○○について調べていらっしゃいましたね」「□□に光が当たりましたね」など具体的に
- 「お疲れさまでした」「明日はまた、ご自身のペースで」など、励ますがプレッシャーをかけない
- 最後に「今日は、まず何から始めますか?」と一言だけ問いかけて締める
- 65〜70歳のご本人にも読みやすい、ゆとりのある言葉で
- 専門用語は避ける`;
    const user = '直近のログ:\n' + JSON.stringify(compact, null, 2);
    const result = await window.satoiChatApi.askClaude(user, { system: system, max_tokens: 900 });
    body.classList.remove('loading');
    body.textContent = result.reply;
    btn.textContent = '🔄 もう一度生成';
    btn.disabled = false;
  } catch(err) {
    body.classList.remove('loading');
    body.textContent = '振り返りの生成に失敗しました:' + (err.message || String(err));
    btn.textContent = '🔄 もう一度試す';
    btn.disabled = false;
  }
}

// 初期表示時に自動でAI振り返りを試みる(ログがあれば)
window.addEventListener('DOMContentLoaded', () => {
  const log = window.satoiLog ? window.satoiLog.read() : [];
  if (log.length >= 3) {
    // ログが3件以上あれば自動生成を試行
    setTimeout(() => generateRecap(), 500);
  } else {
    document.getElementById('recapBody').classList.remove('loading');
    document.getElementById('recapBody').innerHTML = `<div class="recap-empty">まだ、振り返るほどの記録はありませんが、<br>今日から、また一歩ずつ、進めばいいんです。</div>`;
  }
});
</script>

</body>
