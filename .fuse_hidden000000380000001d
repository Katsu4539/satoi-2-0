function toggleAlternatives() {
  const wrap = document.getElementById('altTreatments');
  const toggle = document.getElementById('altToggle');
  if (!wrap || !toggle) return;
  if (wrap.style.display === 'none' || !wrap.style.display) {
    const alts = (ALT_TREATMENTS[cancerKey] || []).filter(t => t.key !== data.royal.key);
    if (!alts.length) {
      wrap.innerHTML = '<div style="color:var(--ink-light); font-size:13px; padding:10px;">他の選択肢は、主治医にご相談ください。</div>';
    } else {
      wrap.innerHTML = alts.map(t =>
        `<a class="alt-card" href="SATOI_Mock_v1_B3_treatment_detail.html?treatment=${t.key}&cancer=${encodeURIComponent(data.name)}&stage=${stage}"><div class="alt-card-name">${t.name}</div><div class="alt-card-desc">${t.desc}</div></a>`
      ).join('');
    }
    wrap.style.display = 'grid';
    toggle.textContent = '× 選択肢を閉じる';
  } else {
    wrap.style.display = 'none';
    toggle.textContent = '他の治療選択肢も見たい →';
  }
}
