<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SATOI - あなたのダッシュボード</title>
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg-deep: #0B1736;
  --bg-mid: #1A2548;
  --ink-on-dark: #F8F6F0;
  --ink-mid: #B8BFD0;
  --ink-light: #8893A8;
  --accent: #D4A95E;
  --accent-strong: #F0C97A;
  --teal: #0D7377;
  --teal-light: #14A6AB;
  --warm: #D4622A;
  --emergency: #B85450;
  --line: rgba(248,246,240,0.12);
  --card-bg: rgba(248,246,240,0.05);
  --font: 'Noto Sans JP', sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: var(--font);
  background: var(--bg-deep);
  color: var(--ink-on-dark);
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
  background-image:
    radial-gradient(ellipse at 30% 0%, rgba(212,169,94,0.08) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 80%, rgba(13,115,119,0.08) 0%, transparent 50%);
  background-attachment: fixed;
  min-height: 100vh;
}
.header {
  position: sticky; top: 0; z-index: 50;
  background: rgba(11,23,54,0.85);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--line);
  padding: 16px 32px; display: flex; align-items: center; gap: 18px;
}
.logo { font-weight: 700; letter-spacing: 0.22em; color: var(--ink-on-dark); font-size: 15px; text-decoration:none; }
.logo .dot { display:inline-block; width:8px; height:8px; background: var(--accent); border-radius: 50%; margin-right: 8px; vertical-align: middle; }
.back-link { margin-left: auto; padding: 8px 18px; background: rgba(248,246,240,0.08); border: 1px solid var(--line); border-radius: 18px; color: var(--ink-on-dark); text-decoration: none; font-size: 13px; }
.back-link:hover { background: rgba(248,246,240,0.16); }

.main { max-width: 1100px; margin: 0 auto; padding: 36px 28px 80px; }

/* ヒーローセクション:状況サマリ */
.hero {
  background: linear-gradient(135deg, rgba(212,169,94,0.12), rgba(13,115,119,0.10));
  border: 1px solid rgba(212,169,94,0.3);
  border-radius: 22px;
  padding: 32px 36px; margin-bottom: 28px;
}
.hero-eyebrow { font-size: 11.5px; color: var(--accent-strong); letter-spacing: 0.22em; margin-bottom: 10px; }
.hero-title { font-size: 30px; font-weight: 700; margin-bottom: 12px; letter-spacing: 0.04em; }
.hero-sub { color: var(--ink-mid); font-size: 14.5px; }
.hero-tags { margin-top: 16px; display: flex; gap: 10px; flex-wrap: wrap; }
.hero-tag {
  padding: 8px 18px; background: rgba(212,169,94,0.18); border: 1px solid rgba(212,169,94,0.5);
  border-radius: 18px; color: var(--accent-strong); font-size: 13px; font-weight: 600;
}

/* メインメトリクス:大きく見せる */
.metrics-row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 32px;
}
.metric-card {
  background: var(--card-bg); border: 1px solid var(--line); border-radius: 18px;
  padding: 28px; position: relative; overflow: hidden;
}
.metric-card.peers { border-color: rgba(13,115,119,0.4); }
.metric-card.survival { border-color: rgba(212,169,94,0.4); }
.metric-label { font-size: 12px; color: var(--ink-light); letter-spacing: 0.18em; margin-bottom: 12px; text-transform: uppercase; }
.metric-main { font-size: 56px; font-weight: 800; color: var(--ink-on-dark); line-height: 1; margin-bottom: 8px; letter-spacing: -0.02em; }
.metric-main .unit { font-size: 26px; font-weight: 500; color: var(--ink-mid); margin-left: 4px; }
.metric-sub { color: var(--ink-mid); font-size: 13.5px; line-height: 1.6; }
.metric-source { font-size: 11px; color: var(--ink-light); margin-top: 10px; font-style: italic; }

/* ステージ別生存率の小グラフ */
.stages-row {
  background: var(--card-bg); border: 1px solid var(--line); border-radius: 18px;
  padding: 24px 28px; margin-bottom: 32px;
}
.stages-title { font-size: 14px; color: var(--ink-mid); margin-bottom: 18px; letter-spacing: 0.04em; }
.stages-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
.stage-cell { background: rgba(248,246,240,0.03); border: 1px solid var(--line); border-radius: 12px; padding: 16px 12px; text-align: center; }
.stage-cell.current { background: rgba(212,169,94,0.15); border-color: var(--accent); }
.stage-cell-label { font-size: 11px; color: var(--ink-light); margin-bottom: 4px; }
.stage-cell-pct { font-size: 22px; font-weight: 700; color: var(--accent-strong); }
.stage-cell.current .stage-cell-pct { color: var(--accent-strong); }

/* セクションタイトル */
.section-title {
  font-size: 18px; font-weight: 700; margin: 28px 0 16px; display: flex; align-items: center; gap: 10px;
  color: var(--ink-on-dark); letter-spacing: 0.04em;
}
.section-title .num { display: inline-flex; width: 28px; height: 28px; border-radius: 50%; background: var(--accent); color: var(--bg-deep); align-items: center; justify-content: center; font-size: 13px; font-weight: 800; }

/* タイムライン:これから起きること */
.timeline-card {
  background: var(--card-bg); border: 1px solid var(--line); border-radius: 18px;
  padding: 24px 28px; margin-bottom: 24px;
}
.tl-flow { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 8px; }
.tl-step {
  flex: 0 0 auto; min-width: 140px;
  background: rgba(248,246,240,0.04); border: 1px solid var(--line); border-radius: 12px;
  padding: 14px 14px; text-align: center;
}
.tl-step.now { background: rgba(212,98,42,0.15); border-color: var(--warm); }
.tl-step-num { font-size: 18px; color: var(--accent); font-weight: 700; }
.tl-step-name { font-size: 12.5px; color: var(--ink-on-dark); margin-top: 6px; }
.tl-step-when { font-size: 10.5px; color: var(--ink-light); margin-top: 4px; }
.tl-arrow { display: flex; align-items: center; color: var(--ink-light); font-size: 16px; }

/* 王道治療カード */
.royal-card {
  background: linear-gradient(135deg, rgba(212,98,42,0.10), rgba(212,169,94,0.08));
  border: 1.5px solid rgba(212,98,42,0.4); border-radius: 18px;
  padding: 24px 28px; margin-bottom: 24px;
}
.royal-eyebrow { font-size: 12px; color: var(--warm); letter-spacing: 0.18em; margin-bottom: 10px; font-weight: 600; }
.royal-name { font-size: 22px; font-weight: 700; margin-bottom: 8px; color: var(--ink-on-dark); }
.royal-desc { color: var(--ink-mid); font-size: 14px; margin-bottom: 14px; }
.royal-cta {
  display: inline-block; padding: 12px 26px; background: var(--warm); color: white;
  border-radius: 24px; text-decoration: none; font-weight: 700; font-size: 14px;
  box-shadow: 0 6px 18px rgba(212,98,42,0.35);
}
.royal-cta:hover { background: #B85420; }
.royal-alt { display: block; margin-top: 18px; text-align: center; }
.royal-alt a { display:inline-block; color: var(--accent-strong); font-size: 16px; font-weight: 600; padding: 13px 30px; border: 1.5px solid rgba(212,169,94,0.55); border-radius: 26px; text-decoration: none; cursor: pointer; transition: all 0.2s; }
.royal-alt a:hover { background: rgba(212,169,94,0.15); }
.alt-treatments { margin-top: 22px; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr)); gap: 14px; }
.alt-card { background: var(--card-bg); border: 1px solid var(--line); border-radius: 14px; padding: 18px 20px; cursor: pointer; transition: all 0.2s; text-decoration:none; color: var(--ink-on-dark); display:block; }
.alt-card:hover { border-color: var(--accent); background: rgba(212,169,94,0.10); transform: translateY(-2px); }
.alt-card-name { font-size: 15px; font-weight: 600; margin-bottom: 5px; }
.alt-card-desc { font-size: 12px; color: var(--ink-light); line-height: 1.6; }

/* 知りたいトピックカード */
.topics-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px;
  margin-bottom: 24px;
}
.topic-card {
  background: var(--card-bg); border: 1px solid var(--line); border-radius: 14px;
  padding: 22px 20px; cursor: pointer; transition: all 0.2s;
  text-decoration: none; color: var(--ink-on-dark); display: block;
}
.topic-card:hover { transform: translateY(-2px); border-color: var(--accent); background: rgba(212,169,94,0.10); }
.topic-icon { font-size: 28px; margin-bottom: 10px; }
.topic-title { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
.topic-desc { font-size: 12px; color: var(--ink-light); }

/* AI窓口 */
.ai-prompt {
  background: linear-gradient(135deg, rgba(13,115,119,0.18), rgba(20,166,171,0.12));
  border: 1.5px solid rgba(13,115,119,0.4); border-radius: 18px;
  padding: 24px 28px; margin: 32px 0; display: flex; align-items: center; gap: 18px;
}
.ai-prompt-icon { width: 50px; height: 50px; border-radius: 50%; background: linear-gradient(135deg, var(--teal), var(--teal-light)); display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
.ai-prompt-text { flex: 1; }
.ai-prompt-title { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
.ai-prompt-sub { color: var(--ink-mid); font-size: 13px; }
.ai-prompt-btn { padding: 12px 24px; background: var(--teal-light); color: white; border: none; border-radius: 22px; font-weight: 700; cursor: pointer; text-decoration: none; font-size: 14px; }
.ai-prompt-btn:hover { background: var(--teal); }

/* 出典フッター */
.sources-foot {
  font-size: 11px; color: var(--ink-light); margin-top: 40px; padding-top: 18px;
  border-top: 1px solid var(--line); line-height: 1.8;
}
.sources-foot a { color: var(--ink-mid); text-decoration: underline; }

@media (max-width: 700px) {
  .metrics-row { grid-template-columns: 1fr; }
  .stages-grid { grid-template-columns: repeat(2, 1fr); }
  .metric-main { font-size: 42px; }
  .hero-title { font-size: 22px; }
}
</style>
</head>
