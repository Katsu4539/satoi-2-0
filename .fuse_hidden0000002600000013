<script>
function satoiNotify(msg, opts) {
  opts = opts || {};
  let host = document.getElementById('satoi-toast-host');
  if (!host) { host = document.createElement('div'); host.id = 'satoi-toast-host'; document.body.appendChild(host); }
  const t = document.createElement('div');
  t.className = 'satoi-toast';
  t.innerHTML = '<span class="satoi-toast-icon">●</span><div style="flex:1;">'+msg.replace(/\n/g,'<br>')+'</div><button class="satoi-toast-close">×</button>';
  host.appendChild(t);
  requestAnimationFrame(()=>t.classList.add('show'));
  const closer = ()=>{ t.classList.remove('show'); setTimeout(()=>t.remove(),450); };
  t.querySelector('.satoi-toast-close').addEventListener('click', closer);
  setTimeout(closer, opts.duration||5000);
}
window.alert = function(msg){ try { satoiNotify(String(msg)); } catch(e){} };

(function setupUnivNav(){
  if (document.getElementById('satoi-univ-nav')) return;
  const nav = document.createElement('div'); nav.id='satoi-univ-nav';
  nav.innerHTML='<button class="satoi-univ-btn" title="戻る">←</button><button class="satoi-univ-btn" title="夜空ホーム">⌂</button><button class="satoi-univ-btn" title="マイページ">👤</button><button class="satoi-univ-btn" title="全体マップ">◎</button><button class="satoi-univ-btn" title="コンシェルジュ">💬</button>';
  document.body.appendChild(nav);
  const btns = nav.querySelectorAll('.satoi-univ-btn');
  btns[0].onclick = () => { if (history.length > 1) history.back(); else location.href='SATOI_Mock_v1_A1_entrance.html'; };
  btns[1].onclick = () => location.href='SATOI_Mock_v1_A1_entrance.html';
  btns[2].onclick = () => location.href='SATOI_Mock_v1_C1_mypage.html';
  btns[3].onclick = () => location.href='SATOI_Mock_v1_B1_hub.html';
  btns[4].onclick = () => location.href='SATOI_Mock_v1_CON_concierge.html';
})();

// TOC アクティブ追従
document.querySelectorAll('.toc-item').forEach(a => a.addEventListener('click', e => {
  document.querySelectorAll('.toc-item').forEach(x => x.classList.remove('active'));
  a.classList.add('active');
}));
</script>
