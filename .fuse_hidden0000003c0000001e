<script>

/* === SATOI 共通リッチトースト関数 === */
(function ensureToastHost(){
  if (document.getElementById('satoi-toast-host')) return;
  document.addEventListener('DOMContentLoaded', () => {
    if (!document.getElementById('satoi-toast-host')) {
      const host = document.createElement('div');
      host.id = 'satoi-toast-host';
      document.body.appendChild(host);
    }
  });
  if (document.body && !document.getElementById('satoi-toast-host')) {
    const host = document.createElement('div');
    host.id = 'satoi-toast-host';
    document.body.appendChild(host);
  }
})();
function satoiNotify(msg, opts) {
  opts = opts || {};
  let host = document.getElementById('satoi-toast-host');
  if (!host) { host = document.createElement('div'); host.id = 'satoi-toast-host'; document.body.appendChild(host); }
  const t = document.createElement('div');
  const kind = opts.kind || (msg.indexOf('✓')===0 ? 'success' : 'info');
  t.className = 'satoi-toast ' + kind;
  const icon = opts.icon || (kind === 'success' ? '✓' : (kind === 'warn' ? '!' : '●'));
  const body = msg.replace(/\\n/g, '\n').replace(/\n/g, '<br>');
  let html = '<span class="satoi-toast-icon">'+icon+'</span><div class="satoi-toast-body">'+body+'</div>';
  if (opts.cta && opts.href) {
    html = html.replace('</div>', '<a class="satoi-toast-cta" href="'+opts.href+'">'+opts.cta+' →</a></div>');
  }
  html += '<button class="satoi-toast-close" aria-label="close">×</button>';
  t.innerHTML = html;
  host.appendChild(t);
  requestAnimationFrame(() => t.classList.add('show'));
  const dur = opts.duration || 4200;
  const closer = () => { t.classList.remove('show'); setTimeout(()=>t.remove(), 450); };
  t.querySelector('.satoi-toast-close').addEventListener('click', closer);
  setTimeout(closer, dur);
  return t;
}
// 既存の alert を全て satoiNotify にフォールバック(他コードからのalert呼び出しもキャッチ)
window.__origAlert = window.alert;

/* === SATOI ユニバーサル横断ナビ JS === */
(function setupUnivNav(){
  function inject(){
    if (document.getElementById('satoi-univ-nav')) return;
    const nav = document.createElement('div');
    nav.id = 'satoi-univ-nav';
    nav.innerHTML = '<button class="satoi-univ-btn" id="satoi-back-btn" title="戻る" aria-label="戻る">←</button>'
      + '<button class="satoi-univ-btn" id="satoi-home-btn" title="夜空ホーム" aria-label="夜空ホーム">⌂</button>'
      + '<button class="satoi-univ-btn" id="satoi-hub-btn" title="全体マップ" aria-label="全体マップ">◎</button>'
      + '<div style="position:relative;"><button class="satoi-univ-btn" id="satoi-lang-btn" title="言語" aria-label="言語">🌐</button>'
      + '<div class="satoi-lang-pop" id="satoi-lang-pop"><button class="satoi-lang-opt active" data-lang="ja">日本語</button><button class="satoi-lang-opt" data-lang="en">English</button><button class="satoi-lang-opt" data-lang="zh">中文</button><button class="satoi-lang-opt" data-lang="ko">한국어</button></div></div>';
    document.body.appendChild(nav);
    document.getElementById('satoi-back-btn').addEventListener('click', () => { if (history.length > 1) history.back(); else location.href='SATOI_Mock_v1_A1_entrance.html'; });
    document.getElementById('satoi-home-btn').addEventListener('click', () => location.href='SATOI_Mock_v1_A1_entrance.html');
    document.getElementById('satoi-hub-btn').addEventListener('click', () => location.href='SATOI_Mock_v1_B1_hub.html');
    const conBtn = document.getElementById('satoi-con-btn'); if (conBtn) conBtn.addEventListener('click', () => location.href='SATOI_Mock_v1_CON_concierge.html');
    const langBtn = document.getElementById('satoi-lang-btn');
    const langPop = document.getElementById('satoi-lang-pop');
    langBtn.addEventListener('click', (e) => { e.stopPropagation(); langPop.classList.toggle('show'); });
    document.addEventListener('click', (e) => { if (!langPop.contains(e.target) && e.target !== langBtn) langPop.classList.remove('show'); });
    langPop.querySelectorAll('.satoi-lang-opt').forEach(b => {
      b.addEventListener('click', () => {
        langPop.querySelectorAll('.satoi-lang-opt').forEach(x => x.classList.remove('active'));
        b.classList.add('active');
        const lang = b.dataset.lang;
        const labels = { ja: '日本語に切り替えました', en: 'Switched to English (translation coming soon)', zh: '已切换到中文(翻译即将推出)', ko: '한국어로 전환되었습니다 (번역 준비 중)' };
        if (typeof satoiNotify === 'function') satoiNotify(labels[lang] || labels.ja, { kind: 'info', duration: 3000 });
        document.documentElement.lang = lang;
        langPop.classList.remove('show');
      });
    });
  }
  if (document.body) inject();
  else document.addEventListener('DOMContentLoaded', inject);
})();

window.alert = function(msg){ try { satoiNotify(String(msg)); } catch(e){ window.__origAlert(msg); } };

/* タブ切替 */
document.querySelectorAll('.emg-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.emg-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.emg-tab-pane').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
  });
});

/* QR生成・再発行 */
let emgQrInstance = null;
function generateQr(payload) {
  const canvas = document.getElementById('emgQrCanvas');
  if (!canvas) return;
  canvas.innerHTML = '';
  if (typeof QRCode === 'undefined') {
    canvas.innerHTML = '<div style="color:#B85450; font-size:12px;">QRライブラリ読込中</div>';
    return;
  }
  emgQrInstance = new QRCode(canvas, {
    text: payload,
    width: 220, height: 220,
    colorDark: '#1A2A40',
    colorLight: '#FFFFFF',
    correctLevel: QRCode.CorrectLevel.H
  });
}

function redoQr() {
  const now = new Date();
  const id = 'SATOI-EMG-' + Math.floor(Math.random()*9000+1000) + '-' + (now.getMonth()+1).toString().padStart(2,'0') + now.getDate().toString().padStart(2,'0') + now.getHours().toString().padStart(2,'0');
  document.getElementById('qrId').textContent = 'ID: ' + id;
  const time = now.toISOString().slice(0,16).replace('T',' ');
  document.getElementById('qrTime').textContent = '発行: ' + time + ' ・ 15分有効';
  // QR を本当に再生成(中身にID・有効期限・SATOI URL を含む)
  const payload = JSON.stringify({
    id: id,
    issued: now.toISOString(),
    expires: new Date(now.getTime() + 15*60*1000).toISOString(),
    url: 'https://vocal-sprinkles-2ec59a.netlify.app/emergency?id=' + id
  });
  generateQr(payload);
  satoiNotify('✓ QR を再発行しました\n\nID: ' + id + '\n15分間有効です。');
}

/* ===== AI 搬送レポート生成(救急隊向けスクリーニング) =====
   患者の最新マイページ更新・治療履歴・直近副作用・服薬情報を
   Claude API に送って、5〜8行の搬送レポートを生成する。  */
async function generateAiTransportReport() {
  const btn = document.getElementById('genAiReportBtn');
  const result = document.getElementById('aiReportResult');
  if (!btn || !result) return;

  // 患者の最新コンテキスト(本来はC1マイページ・F4から動的に取得。Mockではここに集約)
  const patientContext = {
    name: 'M.K.さん',
    age: 58,
    gender: '女性',
    blood_type: 'O型 RH+',
    primary_disease: '乳がん StageII (Luminal A) ・ 2026-04-08 告知',
    current_treatment: 'TC療法 3クール目(ドセタキセル60mg/m² + シクロホスファミド600mg/m²)',
    treatment_history: [
      '乳房温存手術 (2026-04-22)',
      '放射線療法 25回 完了 (2026-05-05)',
      '化学療法 TC 開始 2026-05-12'
    ],
    allergies: ['ペニシリン系', '造影剤(イオパミドール)'],
    contraindications: ['NSAIDs(出血リスク)', '生ワクチン', 'グレープフルーツ'],
    comorbidities: ['高血圧(内服中)', '脂質異常症', '帝王切開既往(2008)'],
    recent_labs_2026_05_15: {
      white_blood_cells: 2800,
      neutrophils: 1420,
      hemoglobin: 10.2,
      platelets: 185000,
      note: '白血球低値・好中球減少・易感染性'
    },
    recent_side_effects_last_24h: {
      nausea: '7/10',
      fatigue: '8/10',
      appetite_loss: '5/10',
      numbness: '3/10',
      last_record: '2026-05-19 18:30'
    },
    supportive_meds: ['プレドニン 5mg/日', 'オランザピン 2.5mg(吐き気時)', 'アムロジピン 5mg(高血圧)'],
    last_consultation: '2026-05-15 主治医面談・次回CT 2026-05-22',
    primary_contact: '拠点病院 腫瘍内科 24時間オンコール'
  };

  btn.disabled = true;
  btn.textContent = '🔄 AI生成中…';
  result.style.display = 'block';
  result.innerHTML = '<div style="padding:14px; background:white; border-radius:10px; color:var(--ink-medium); font-size:13px;">Claude AI に問い合わせ中です…<br><span style="font-size:11.5px; color:var(--ink-light);">最新マイページ更新と治療履歴を分析しています。15〜30秒お待ちください。</span></div>';

  try {
    if (!window.satoiChatApi) throw new Error('satoi_chat_api.js が読み込まれていません');
    const report = await window.satoiChatApi.generateTransportReport(patientContext);
    const now = new Date().toISOString().slice(0,16).replace('T',' ');
    result.innerHTML = `
      <div style="padding:18px; background:white; border-radius:10px; border:1px solid rgba(184,84,80,0.2);">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:12px;">
          <div style="font-weight:700; color:var(--emergency-red); font-size:14px;">📋 AI 搬送スクリーニング・レポート</div>
          <div style="font-size:11px; color:var(--ink-light); margin-left:auto;">生成: ${now}</div>
        </div>
        <div style="font-size:13.5px; color:var(--ink-deep); line-height:1.8; white-space:pre-wrap;">${escapeHtml(report)}</div>
        <div style="margin-top:14px; padding-top:12px; border-top:1px dashed rgba(11,23,54,0.15); font-size:11px; color:var(--ink-light);">
          ※ このレポートはAIによる参考情報です。最終判断は搬送先医師の臨床評価に従ってください。
        </div>
      </div>`;
    btn.textContent = '🔄 AI再生成';
    btn.disabled = false;
  } catch (err) {
    result.innerHTML = `<div style="padding:14px; background:#FFF0F0; border-radius:10px; color:var(--emergency-red); font-size:13px;">AI レポート生成に失敗しました。<br><span style="font-size:11.5px;">${escapeHtml(err.message || String(err))}</span></div>`;
    btn.textContent = '🔄 もう一度試す';
    btn.disabled = false;
  }
}

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]);
}

/* 初期QR生成(ページロード時) */
window.addEventListener('DOMContentLoaded', () => {
  const initialId = document.getElementById('qrId').textContent.replace('ID: ', '');
