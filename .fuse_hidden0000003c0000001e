<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SATOI - 緊急QR ・ 救急現場での開示</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
:root {
  --night-deep: #0B1736;
  --night-medium: #1A2548;
  --emergency-red: #B85450;
  --emergency-red-glow: #D86560;
  --warm-orange: #D4622A;
  --warm-coral: #E08461;
  --starlight: #D4A95E;
  --starlight-strong: #F0C97A;
  --morning-white: #FBF7F0;
  --morning-cream: #F6EFE3;
  --teal: #0D7377;
  --teal-soft: #14A6AB;
  --healing-blue: #7FA8C9;
  --ink-deep: #1A2A40;
  --ink-medium: rgba(26,42,64,0.75);
  --ink-light: rgba(26,42,64,0.55);
  --line: rgba(10,22,40,0.10);
  --font: "Noto Sans JP", "Meiryo UI", "Hiragino Kaku Gothic ProN", sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { width: 100%; min-height: 100vh; overflow-x: hidden; }
body {
  font-family: var(--font);
  color: var(--ink-deep);
  background: linear-gradient(135deg, #0B1736 0%, #1A2548 100%);
  line-height: 1.8;
  font-size: 16px;
  min-height: 100vh;
}
a { color: inherit; text-decoration: none; }
button { font-family: var(--font); cursor: pointer; }

/* === ヘッダー === */
.header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 16px 28px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(11,23,54,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(248,246,240,0.08);
}
.logo {
  font-size: 20px; font-weight: 500; letter-spacing: 0.22em;
  color: var(--morning-white);
  display: inline-flex; align-items: center;
}
.logo .dot {
  width: 8px; height: 8px;
  background: var(--emergency-red-glow);
  border-radius: 50%;
  margin-right: 10px;
  box-shadow: 0 0 12px var(--emergency-red-glow);
  animation: emergencyPulse 1.4s infinite;
}
@keyframes emergencyPulse {
  0%, 100% { opacity: 0.7; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.18); }
}
.back-btn {
  padding: 8px 18px;
  background: rgba(248,246,240,0.08);
  color: var(--morning-white);
  border: 1px solid rgba(248,246,240,0.22);
  border-radius: 20px;
  font-size: 12px;
  letter-spacing: 0.06em;
}
.back-btn:hover { background: rgba(248,246,240,0.15); border-color: var(--starlight); }

/* === メイン === */
.emg-wrap {
  max-width: 980px;
  margin: 0 auto;
  padding: 110px 28px 80px;
}

/* === 緊急ヒーローバナー === */
.emg-banner {
  background: linear-gradient(135deg, #B85450 0%, #D4622A 100%);
  border-radius: 24px;
  padding: 28px 32px;
  display: flex;
  align-items: center;
  gap: 22px;
  margin-bottom: 28px;
  box-shadow: 0 16px 50px rgba(184,84,80,0.4);
  position: relative;
  overflow: hidden;
}
.emg-banner::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 80% 20%, rgba(248,246,240,0.18), transparent 60%);
  pointer-events: none;
}
.emg-icon {
  width: 64px; height: 64px;
  border-radius: 50%;
  background: rgba(248,246,240,0.18);
  border: 2px solid rgba(248,246,240,0.42);
  display: flex; align-items: center; justify-content: center;
  font-size: 30px;
  flex-shrink: 0;
  animation: emergencyPulse 1.6s infinite;
}
.emg-banner-text {
  color: white;
  flex: 1;
}
.emg-banner-eyebrow {
  font-size: 11px;
  letter-spacing: 0.42em;
  margin-bottom: 6px;
  opacity: 0.92;
}
.emg-banner-title {
  font-size: 22px;
  font-weight: 500;
  margin-bottom: 6px;
  letter-spacing: 0.04em;
}
.emg-banner-sub {
  font-size: 13px;
  opacity: 0.88;
  line-height: 1.7;
}

/* === グリッド: QR + 開示内容 === */
.emg-grid {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 28px;
  margin-bottom: 28px;
}
.emg-qr-card {
  background: var(--morning-white);
  border-radius: 22px;
  padding: 28px 24px 24px;
  box-shadow: 0 16px 40px rgba(0,0,0,0.3);
  text-align: center;
}
.emg-qr-title {
  font-size: 13px;
  letter-spacing: 0.22em;
  color: var(--emergency-red);
  font-weight: 600;
  margin-bottom: 14px;
}
.emg-qr {
  width: 240px; height: 240px;
  margin: 0 auto 16px;
  background: white;
  border: 3px solid var(--ink-deep);
  border-radius: 14px;
  padding: 12px;
  display: block;
}
.emg-qr svg { width: 100%; height: 100%; }
.emg-qr-id {
  font-size: 11px;
  font-family: monospace;
  color: var(--ink-light);
  letter-spacing: 0.18em;
  margin-bottom: 6px;
}
.emg-qr-time {
  font-size: 12px;
  color: var(--ink-medium);
  margin-bottom: 14px;
}
.emg-qr-btn {
  width: 100%;
  padding: 12px;
  background: var(--emergency-red);
  color: white;
  border: none;
  border-radius: 18px;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.06em;
  margin-bottom: 8px;
  cursor: pointer;
  transition: background 0.3s;
}
.emg-qr-btn:hover { background: var(--emergency-red-glow); }
.emg-qr-btn.secondary { background: var(--ink-deep); }
.emg-qr-btn.secondary:hover { background: var(--night-medium); }
.emg-qr-note {
  font-size: 10.5px;
  color: var(--ink-light);
  margin-top: 10px;
  line-height: 1.7;
}

/* 開示内容パネル */
.emg-content {
  background: var(--morning-white);
  border-radius: 22px;
  padding: 28px;
  box-shadow: 0 16px 40px rgba(0,0,0,0.3);
}
.emg-content-tabs {
  display: flex;
  gap: 4px;
  margin-bottom: 22px;
  border-bottom: 1px solid var(--line);
  overflow-x: auto;
}
.emg-tab {
  padding: 12px 18px;
  background: transparent;
  border: none;
  font-size: 13px;
  color: var(--ink-medium);
  cursor: pointer;
  position: relative;
  white-space: nowrap;
  font-family: var(--font);
  transition: color 0.2s;
}
.emg-tab.active {
  color: var(--emergency-red);
  font-weight: 600;
}
.emg-tab.active::after {
  content: '';
  position: absolute;
  bottom: -1px; left: 18px; right: 18px;
  height: 2.5px;
  background: var(--emergency-red);
  border-radius: 2px;
}
.emg-tab-pane { display: none; }
.emg-tab-pane.active { display: block; animation: tabFade 0.4s ease; }
@keyframes tabFade {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}

.emg-row {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 18px;
  padding: 12px 0;
  border-bottom: 1px dashed var(--line);
  font-size: 13.5px;
}
.emg-row:last-child { border-bottom: none; }
.emg-row-label {
  color: var(--ink-light);
  font-size: 11.5px;
  letter-spacing: 0.06em;
  padding-top: 2px;
}
.emg-row-value {
  color: var(--ink-deep);
  line-height: 1.75;
}
.emg-row-value strong { color: var(--emergency-red); }

.emg-warn-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 10px;
  background: rgba(184,84,80,0.10);
  color: var(--emergency-red);
  border: 1px solid rgba(184,84,80,0.3);
  border-radius: 12px;
  font-size: 11px;
  font-weight: 600;
  margin-right: 6px;
  margin-bottom: 4px;
}
.emg-chip {
  display: inline-flex;
  padding: 3px 9px;
  background: rgba(212,169,94,0.18);
  color: #8B5A1F;
  border-radius: 10px;
  font-size: 11px;
  margin-right: 4px;
  margin-bottom: 3px;
}

/* === 開示同意 === */
.emg-consent {
  background: rgba(255,253,247,0.96);
  border-radius: 18px;
  padding: 22px 26px;
  margin-bottom: 22px;
  border-left: 4px solid var(--starlight);
}
.emg-consent-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--ink-deep);
  margin-bottom: 8px;
}
.emg-consent-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 10px;
  margin-top: 12px;
}
.emg-consent-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  background: white;
  border-radius: 12px;
  border: 1px solid var(--line);
  font-size: 12.5px;
  cursor: pointer;
}
.emg-consent-row input { cursor: pointer; }
.emg-consent-row.locked {
  background: rgba(212,169,94,0.10);
  border-color: rgba(212,169,94,0.4);
  cursor: not-allowed;
}

/* === 連絡先 === */
.emg-contacts {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 12px;
  margin-top: 14px;
}
.emg-contact-card {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 18px;
  background: rgba(13,115,119,0.06);
  border: 1px solid rgba(13,115,119,0.18);
  border-radius: 14px;
  cursor: pointer;
  transition: all 0.3s;
}
.emg-contact-card:hover {
  background: rgba(13,115,119,0.12);
  border-color: var(--teal);
  transform: translateY(-2px);
}
.emg-contact-role {
  font-size: 11px;
  color: var(--teal);
  margin-bottom: 2px;
}
.emg-contact-name {
  font-size: 13.5px;
  color: var(--ink-deep);
  font-weight: 500;
}
.emg-contact-num {
  font-size: 12px;
  color: var(--ink-light);
  font-family: monospace;
}
.emg-contact-call {
  margin-left: auto;
  width: 36px; height: 36px;
  border-radius: 50%;
  background: var(--teal);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}

/* === ACP === */
.emg-acp {
  background: linear-gradient(135deg, rgba(127,168,201,0.10), rgba(212,169,94,0.10));
  border-radius: 16px;
  padding: 20px 24px;
  border: 1px solid rgba(127,168,201,0.3);
  font-size: 13px;
  line-height: 1.95;
  color: var(--ink-medium);
}
.emg-acp strong { color: var(--ink-deep); }

/* === フッターアクション === */
.emg-footer {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 22px;
}
.emg-foot-btn {
  padding: 14px 26px;
  border-radius: 24px;
  font-size: 13px;
  font-weight: 500;
  border: none;
  cursor: pointer;
  transition: all 0.3s;
}
.emg-foot-btn-primary {
  background: var(--morning-white);
  color: var(--emergency-red);
}
.emg-foot-btn-primary:hover { background: var(--starlight-strong); color: var(--ink-deep); }
.emg-foot-btn-ghost {
  background: transparent;
  color: var(--morning-white);
  border: 1px solid rgba(248,246,240,0.42);
}
.emg-foot-btn-ghost:hover { background: rgba(248,246,240,0.10); }

@media (max-width: 768px) {
  .emg-grid { grid-template-columns: 1fr; }
  .emg-banner { flex-direction: column; text-align: center; padding: 22px; }
  .emg-qr { width: 200px; height: 200px; }
  .header { padding: 12px 16px; }
  .emg-wrap { padding: 96px 16px 60px; }
}

/* === SATOI 共通リッチトースト(alert置換)=== */
#satoi-toast-host { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 9999; display: flex; flex-direction: column; gap: 10px; pointer-events: none; max-width: 92vw; }
.satoi-toast { pointer-events: auto; min-width: 280px; max-width: 480px; background: linear-gradient(135deg, rgba(11,23,54,0.96), rgba(26,37,72,0.96)); color: #F8F6F0; padding: 16px 22px 16px 18px; border-radius: 16px; box-shadow: 0 16px 40px rgba(11,23,54,0.35), 0 0 0 1px rgba(212,169,94,0.30); font-family: "Noto Sans JP", "Meiryo UI", sans-serif; font-size: 13.5px; line-height: 1.75; backdrop-filter: blur(14px); display: flex; gap: 14px; align-items: flex-start; opacity: 0; transform: translateY(20px); transition: opacity 0.4s cubic-bezier(0.4,0,0.2,1), transform 0.4s cubic-bezier(0.4,0,0.2,1); border-left: 3px solid #D4A95E; }
.satoi-toast.show { opacity: 1; transform: translateY(0); }
.satoi-toast.success { border-left-color: #14A6AB; }
.satoi-toast.info { border-left-color: #D4A95E; }
.satoi-toast.warn { border-left-color: #D4622A; }
.satoi-toast-icon { flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%; background: rgba(212,169,94,0.18); display: inline-flex; align-items: center; justify-content: center; font-size: 14px; }
.satoi-toast.success .satoi-toast-icon { background: rgba(20,166,171,0.20); }
.satoi-toast.warn .satoi-toast-icon { background: rgba(212,98,42,0.20); }
.satoi-toast-body { flex: 1; white-space: pre-line; }
.satoi-toast-body strong { color: #F0C97A; font-weight: 600; }
.satoi-toast-close { background: transparent; border: none; color: rgba(248,246,240,0.5); cursor: pointer; font-size: 18px; line-height: 1; padding: 2px 4px; }
.satoi-toast-close:hover { color: #F0C97A; }
.satoi-toast-cta { margin-top: 8px; display: inline-block; padding: 6px 14px; background: rgba(212,169,94,0.20); color: #F0C97A; border: 1px solid rgba(212,169,94,0.5); border-radius: 14px; font-size: 11.5px; cursor: pointer; transition: all 0.2s; text-decoration: none; }
.satoi-toast-cta:hover { background: #D4A95E; color: #0B1736; }
@media (max-width: 768px) {
  #satoi-toast-host { bottom: 14px; }
  .satoi-toast { min-width: auto; width: calc(100vw - 28px); padding: 14px 16px; font-size: 12.5px; }
}


/* === SATOI 共通モバイル対応(iPad/iPhone)=== */
@media (max-width: 1024px) {
  /* iPad 縦 ・ ヘッダー狭め */
  .header { padding: 14px 22px !important; }
  .section, .wrap, .container, main, .main { padding-left: 22px !important; padding-right: 22px !important; }
}
@media (max-width: 768px) {
  /* iPhone ・ 主要メトリクスをモバイル最適化 */
  html { font-size: 15px; }
  body { font-size: 15px; line-height: 1.75; }
  .header { padding: 12px 14px !important; }
  h1, .hero-title, .hero-title-l1 { font-size: clamp(24px, 6vw, 32px) !important; line-height: 1.5 !important; }
  h2, .section-title, .nbm-title, .mission-line { font-size: clamp(20px, 5vw, 28px) !important; line-height: 1.55 !important; }
  h3 { font-size: 17px !important; }
  .section, .container, .wrap, main, .main, section { padding-left: 14px !important; padding-right: 14px !important; }
  section, .section { padding-top: 50px !important; padding-bottom: 50px !important; }
  /* グリッドを1列に */
  .grid, .cards, .types-grid, .stories-grid, .forum-grid, .family-grid, .promise-list, .partner-grid, .gov-grid, .numbers-grid, .empse-grid, .pubmed-list, .sources-grid, .criteria-grid, .tx-cat-grid, .map-wrap, .emg-grid, .emg-consent-grid, .emg-contacts, .kids-talk-wrap, .cat-grid, .videos-grid, .cat-cards, .partner-cards, .promise-cards, .principle-cards, .pricing-grid, .pricing-cards, .step-cards, .info-cards, .role-cards, .news-grid {
    grid-template-columns: 1fr !important;
    gap: 14px !important;
  }
  /* 横スクロールのみ許す要素は残す */
  .b1-journey-bar, .journey-bar, .types-tabs { overflow-x: auto !important; -webkit-overflow-scrolling: touch; }
  /* ヒーローの padding 圧縮 */
  .hero { padding: 90px 14px 50px !important; min-height: auto !important; }
  /* 大きい見出し */
  .opener-line { font-size: 24px !important; margin-bottom: 40px !important; }
  /* タップ領域 44px 最低 */
  .btn, button, .login-btn, .nav-mini a, .filter-chip, .cat-card, .type-card, .story-card, .forum-card { min-height: 40px; }
  /* テーブル横スクロール */
  table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  /* マイチーム ホイール → 縦並びに */
  .team-wheel-wrap, .team-wheel { width: 100% !important; height: auto !important; min-height: 360px; }
  /* モーダル系: 画面いっぱいに */
  .modal, .overlay-modal, [class*='Modal'], [class*='modal'] { max-width: 100vw !important; }
  /* ナビ縮小 */
  .nav-mini, .nav { gap: 12px !important; font-size: 12px !important; }
  /* フォーム入力 */
  input, textarea, select { font-size: 16px !important; } /* iOSのズーム防止 */
  /* SVG レーダーチャートの収まり */
  .empse-chart, .empse-chart-wrap { width: 100% !important; max-width: 320px; height: auto !important; margin: 0 auto !important; }
  /* B1 7ステップを横スクロールに */
  .steps-row { overflow-x: auto; -webkit-overflow-scrolling: touch; gap: 10px; }
  .steps-row .step { flex-shrink: 0; min-width: 80px; }
  /* G2 サイドナビは画面下部固定 or hamburger 想定 */
  .sidebar, .side-nav, .g2-sidebar { position: relative !important; width: 100% !important; height: auto !important; overflow-x: auto !important; display: flex !important; }
}
@media (max-width: 480px) {
  /* 極小画面 */
  .hero { padding: 80px 12px 40px !important; }
  .b1-journey-bar { padding: 8px 10px !important; }
  .satoi-toast { font-size: 12px; padding: 12px 14px; }
}


/* === SATOI ユニバーサル横断ナビ(戻る/ホーム/言語) === */
#satoi-univ-nav { position: fixed; top: 50%; right: 14px; transform: translateY(-50%); z-index: 9998; display: flex; flex-direction: column; gap: 8px; pointer-events: none; }
.satoi-univ-btn { pointer-events: auto; width: 44px; height: 44px; border-radius: 50%; background: rgba(11,23,54,0.85); color: #F0C97A; border: 1px solid rgba(212,169,94,0.4); display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 16px; backdrop-filter: blur(10px); transition: all 0.3s; box-shadow: 0 6px 18px rgba(11,23,54,0.25); font-family: inherit; }
.satoi-univ-btn:hover { background: #D4A95E; color: #0B1736; transform: scale(1.1); }
.satoi-univ-btn[title]::after { content: attr(title); position: absolute; right: 54px; background: rgba(11,23,54,0.92); color: #F8F6F0; font-size: 11px; padding: 4px 10px; border-radius: 8px; white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
.satoi-univ-btn:hover::after { opacity: 1; }
.satoi-lang-pop { position: absolute; right: 54px; top: 0; background: rgba(11,23,54,0.94); border: 1px solid rgba(212,169,94,0.4); border-radius: 12px; padding: 6px; min-width: 130px; display: none; flex-direction: column; gap: 2px; box-shadow: 0 14px 30px rgba(0,0,0,0.4); }
.satoi-lang-pop.show { display: flex; }
.satoi-lang-opt { padding: 8px 14px; border-radius: 8px; color: #F8F6F0; font-size: 12px; cursor: pointer; text-align: left; background: transparent; border: none; font-family: inherit; }
.satoi-lang-opt:hover { background: rgba(212,169,94,0.18); color: #F0C97A; }
.satoi-lang-opt.active { background: rgba(212,169,94,0.25); color: #F0C97A; font-weight: 600; }
@media (max-width: 768px) { #satoi-univ-nav { right: 8px; bottom: 80px; top: auto; transform: none; } .satoi-univ-btn { width: 40px; height: 40px; font-size: 14px; } }

</style>
</head>
<body>

<header class="header">
  <a href="SATOI_Mock_v1_F4_side_effects.html" class="logo"><span class="dot"></span>SATOI ・ 緊急開示</a>
  <button class="back-btn" onclick="history.back()">← 戻る</button>
</header>

<main class="emg-wrap">

  <!-- 緊急バナー -->
  <div class="emg-banner">
    <div class="emg-icon">🚨</div>
    <div class="emg-banner-text">
